function createCarpetMicroExplosion(position, seed) {
  const hf = (salt) => (((seed * 2246822519) ^ (salt * 3266489917)) >>> 0) / 4294967296;
  if (seed % 37 === 0) {
    const scale = 0.05 + hf(0) * 0.07;
    createCrater(position, scale * 0.35);
  }
  applyMegacityExplosionDamage(position, SHELL_TYPES.highExplosive, 0.078 + hf(1) * 0.052);
  damageStructures(position, 0.26 + hf(2) * 0.22);
  if (seed % 11 === 0) {
    scheduleCameraShake(position, 0.028 + hf(3) * 0.05);
  }
  if (seed % 8 === 0) {
    const kind = `carpetM${seed % 12}`;
    registerTerrainShockwave(position, 0.26 + hf(4) * 0.48, kind);
  }

  GameAudio.playCarpetMicroBang(position, seed);

  if (activeLightExplosions.length > 220) {
    return;
  }

  const hue = 0.06 + hf(5) * 0.09;
  const coreCol = new THREE.Color().setHSL(hue, 0.85, 0.55);
  const haloCol = new THREE.Color().setHSL(hue + 0.04 * (hf(6) - 0.5), 0.75, 0.48);
  const ringCol = new THREE.Color().setHSL(hue - 0.03 * (hf(7) - 0.5), 0.6, 0.58);
  const s0 = 0.35 + hf(8) * 0.55;
  const seg = 12 + Math.floor(hf(9) * 22);
  const dur = 0.36 + hf(10) * 0.42;
  const ri = 0.45 + hf(11) * 0.55;
  const ro = ri + 0.55 + hf(12) * 1.15;

  const root = new THREE.Group();
  root.position.copy(position);
  scene.add(root);

  const core = new THREE.Mesh(
    new THREE.SphereGeometry(0.85 * s0, 10, 10),
    new THREE.MeshBasicMaterial({ color: coreCol, transparent: true, opacity: 0.88 }),
  );
  root.add(core);

  const halo = new THREE.Mesh(
    new THREE.SphereGeometry(1.15 * s0, 10, 10),
    new THREE.MeshBasicMaterial({ color: haloCol, transparent: true, opacity: 0.55 }),
  );
  root.add(halo);

  const shockwave = new THREE.Mesh(
    new THREE.RingGeometry(ri, ro, seg),
    new THREE.MeshBasicMaterial({
      color: ringCol,
      side: THREE.DoubleSide,
      transparent: true,
      opacity: 0.72,
    }),
  );
  shockwave.rotation.x = -Math.PI / 2;
  root.add(shockwave);

  const scorch = new THREE.Mesh(
    new THREE.CircleGeometry(1.35 * s0 + hf(13) * 0.8, Math.max(8, seg - 2)),
    new THREE.MeshBasicMaterial({
      color: 0x1a1510,
      transparent: true,
      opacity: 0.45,
      side: THREE.DoubleSide,
    }),
  );
  scorch.rotation.x = -Math.PI / 2;
  scorch.position.y = 0.015;
  root.add(scorch);

  activeLightExplosions.push({
    root,
    core,
    halo,
    shockwave,
    scorch,
    age: 0,
    duration: dur,
    carpetSwMul: 0.65 + hf(14) * 0.55,
  });
}

