  function playJetDistant(worldPos) {
    const c = getCtx();
    if (!c) return;
    const t = c.currentTime;
    const dist = distanceToListener(worldPos);
    const spatial = spatialVolume(dist, { ref: 75, power: 0.5, ceiling: 0.55 });
    const dur = 2.4;
    const n = Math.floor(c.sampleRate * dur);
    const buf = c.createBuffer(1, n, c.sampleRate);
    const ch = buf.getChannelData(0);
    for (let i = 0; i < n; i++) {
      ch[i] = (Math.random() * 2 - 1) * 0.35;
