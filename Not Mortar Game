    const src = c.createBufferSource();
    src.buffer = buf;
    const f = c.createBiquadFilter();
    f.type = "lowpass";
    f.frequency.setValueAtTime(280, t);
    f.frequency.linearRampToValueAtTime(95, t + dur);
    const g = c.createGain();
    g.gain.setValueAtTime(0.0001, t);
    g.gain.linearRampToValueAtTime(spatial * 0.32, t + 0.4);
    g.gain.linearRampToValueAtTime(spatial * 0.22, t + dur * 0.55);
    g.gain.linearRampToValueAtTime(0.0001, t + dur);
    src.connect(f);
    f.connect(g);
    g.connect(masterGain);
    src.start(t);
    src.stop(t + dur + 0.05);
  }

  return {
    resume,
    playExplosion,
    playLightExplosion,
    playCarpetMicroBang,
    playMortarLaunch,
    playShellClack,
    playShellLoad,
    playRadioPickup,
    playMapOpen,
    playMortarRotateToggle,
    playJetDistant,
  };
})();

