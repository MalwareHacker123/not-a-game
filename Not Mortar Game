<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Player Camera Demo</title>
    <style>
      :root {
        color: #f4f7fb;
        background: #0f1720;
        font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body,
      #app {
        margin: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
      }

      #app {
        position: relative;
        isolation: isolate;
      }

      body {
        background:
          radial-gradient(circle at top, rgba(91, 127, 198, 0.35), transparent 45%),
          linear-gradient(180deg, #17212f 0%, #0d121a 100%);
      }

      #app canvas {
        display: block;
        position: relative;
        z-index: 2;
        pointer-events: none;
      }

      #app canvas.pointer-active {
        pointer-events: auto;
      }

      .hud {
        position: fixed;
        inset: 0;
        z-index: 7;
        pointer-events: none;
      }

      .hud__status {
        position: absolute;
        left: 50%;
        bottom: 1.5rem;
        transform: translateX(-50%);
        padding: 0.55rem 0.85rem;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(15, 23, 32, 0.72);
        font-size: 0.9rem;
        color: rgba(244, 247, 251, 0.95);
      }

      .hud__score {
        position: absolute;
        top: 1rem;
        right: 1rem;
        padding: 0.55rem 0.9rem;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(15, 23, 32, 0.72);
        font-size: 0.9rem;
        color: rgba(244, 247, 251, 0.95);
      }

      .hud__trajectory {
        position: absolute;
        top: 1rem;
        left: 1rem;
        padding: 0.6rem 0.9rem;
        border-radius: 14px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(15, 23, 32, 0.72);
        font-size: 0.88rem;
        color: rgba(244, 247, 251, 0.95);
        min-width: 13rem;
      }

      .hud__trajectory[hidden] {
        display: none;
      }

      .hud__trajectory-label {
        display: block;
        margin-bottom: 0.18rem;
        font-size: 0.76rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: rgba(244, 247, 251, 0.62);
      }

      .hud__crosshair {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 18px;
        height: 18px;
        transform: translate(-50%, -50%);
      }

      .hud__crosshair::before,
      .hud__crosshair::after {
        content: "";
        position: absolute;
        inset: 0;
        margin: auto;
        background: rgba(255, 255, 255, 0.95);
        border-radius: 999px;
      }

      .hud__crosshair::before {
        width: 2px;
        height: 18px;
      }

      .hud__crosshair::after {
        width: 18px;
        height: 2px;
      }

      .binocular-overlay {
        position: fixed;
        inset: 0;
        z-index: 6;
        pointer-events: none;
      }

      .binocular-overlay[hidden] {
        display: none !important;
      }

      .binocular-overlay__lens {
        position: absolute;
        top: 50%;
        width: min(38vw, 44vh);
        height: min(38vw, 44vh);
        border-radius: 50%;
        transform: translateY(-50%);
        border: min(0.75vw, 9px) solid #141210;
        box-shadow:
          inset 0 0 min(1.5vw, 15px) rgba(0, 0, 0, 0.38),
          inset 0 0 0 min(0.28vw, 3px) rgba(255, 248, 235, 0.09),
          0 0 0 max(120vmax, 220vh) rgba(0, 0, 0, 0.68);
      }

      .binocular-overlay__lens--left {
        left: 50%;
        transform: translate(calc(-100% - min(0.75vw, 7px)), -50%);
      }

      .binocular-overlay__lens--right {
        left: 50%;
        transform: translate(min(0.75vw, 7px), -50%);
      }

      .binocular-overlay__lens::after {
        content: "";
        position: absolute;
        inset: 10%;
        border-radius: 50%;
        box-shadow: inset 0 0 min(1.25vw, 13px) rgba(0, 0, 0, 0.28);
        pointer-events: none;
      }

      .binocular-overlay__bridge {
        position: absolute;
        top: 50%;
        left: 50%;
        width: min(1.9vw, 16px);
        height: min(6vw, 7vh);
        transform: translate(-50%, -50%);
        margin-top: min(0.7vh, 5px);
        background: linear-gradient(
          180deg,
          rgba(18, 16, 14, 0.95) 0%,
          rgba(28, 25, 22, 0.88) 45%,
          rgba(18, 16, 14, 0.95) 100%
        );
        border-radius: min(0.5vw, 6px);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
      }

      .hud__binocular-zoom {
        position: absolute;
        bottom: 4.5rem;
        left: 50%;
        transform: translateX(-50%);
        padding: 0.35rem 0.75rem;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.14);
        background: rgba(12, 18, 26, 0.78);
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        color: rgba(200, 230, 255, 0.95);
      }

      .hud__binocular-zoom[hidden] {
        display: none;
      }

      .compass-hud {
        position: fixed;
        z-index: 100002;
        left: 50%;
        bottom: min(14vh, 8rem);
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.35rem;
        pointer-events: none;
        filter: drop-shadow(0 10px 24px rgba(0, 0, 0, 0.45));
      }

      .compass-hud[hidden] {
        display: none !important;
      }

      .compass-hud__hint {
        margin: 0;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: rgba(200, 220, 255, 0.78);
      }

      .compass-hud__circle {
        position: relative;
        width: min(38vw, 180px);
        height: min(38vw, 180px);
        border-radius: 50%;
        border: 3px solid rgba(55, 65, 80, 0.95);
        background:
          radial-gradient(circle at 35% 30%, rgba(255, 255, 255, 0.1), transparent 55%),
          radial-gradient(circle at 50% 50%, #1a2434 0%, #0f141c 100%);
        box-shadow: inset 0 0 18px rgba(0, 0, 0, 0.45), 0 0 0 1px rgba(255, 255, 255, 0.06);
      }

      .compass-hud__dial {
        position: absolute;
        inset: 10px;
        border-radius: 50%;
        transform-origin: 50% 50%;
        will-change: transform;
        --cmp-r: min(15.5vw, 72px);
      }

      .compass-hud__cardinal {
        position: absolute;
        left: 50%;
        top: 50%;
        width: 1.5rem;
        margin-left: -0.75rem;
        text-align: center;
        font-size: 0.9rem;
        font-weight: 800;
        line-height: 1;
        color: rgba(244, 247, 251, 0.92);
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.55);
        transform: rotate(var(--cmp-a, 0deg)) translateY(calc(-1 * var(--cmp-r))) rotate(calc(-1 * var(--cmp-a, 0deg)));
      }

      .compass-hud__cardinal--n {
        color: #fecaca;
      }

      .compass-hud__lubber {
        position: absolute;
        top: -5px;
        left: 50%;
        transform: translateX(-50%);
        width: 0;
        height: 0;
        border-left: 9px solid transparent;
        border-right: 9px solid transparent;
        border-bottom: 15px solid rgba(249, 115, 22, 0.98);
        filter: drop-shadow(0 2px 3px rgba(0, 0, 0, 0.35));
        z-index: 2;
      }

      .compass-hud__readout {
        font-family: ui-monospace, "Cascadia Mono", monospace;
        font-size: 0.98rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        color: rgba(255, 248, 235, 0.96);
        padding: 0.2rem 0.6rem;
        border-radius: 10px;
        background: rgba(12, 18, 28, 0.85);
        border: 1px solid rgba(255, 255, 255, 0.12);
      }

      .compass-hud__readout--tube {
        font-size: 0.82rem;
        letter-spacing: 0.06em;
        color: rgba(186, 230, 253, 0.95);
        border-color: rgba(125, 211, 252, 0.22);
      }

      .compass-hud__readout--tube[hidden] {
        display: none !important;
      }

      .loading-screen {
        position: fixed;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1.5rem;
        padding: 2rem;
        background: linear-gradient(180deg, #0d121a 0%, #17212f 100%);
        z-index: 200;
        pointer-events: auto;
      }

      .loading-screen[hidden] {
        display: none;
      }

      .loading-screen__title {
        margin: 0;
        font-size: 1.4rem;
        font-weight: 700;
        color: #f4f7fb;
      }

      .loading-screen__bar-wrap {
        width: min(20rem, 90%);
        height: 8px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 999px;
        overflow: hidden;
      }

      .loading-screen__bar {
        height: 100%;
        width: 0%;
        background: linear-gradient(90deg, #4cc0ff 0%, #89f4ff 100%);
        border-radius: 999px;
        transition: width 0.15s ease-out;
      }

      .loading-screen__text {
        margin: 0;
        font-size: 0.9rem;
        color: rgba(244, 247, 251, 0.7);
      }

      .start-screen {
        position: fixed;
        inset: 0;
        display: none;
        place-items: center;
        padding: 1.5rem;
        background: rgba(8, 12, 18, 0.78);
        backdrop-filter: blur(10px);
        z-index: 100;
        pointer-events: auto;
      }

      .start-screen.ready {
        display: grid !important;
      }

      .start-screen[hidden] {
        display: none !important;
      }

      .start-screen__panel {
        width: min(100%, 26rem);
        padding: 1.4rem;
        text-align: center;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 18px;
        background: rgba(15, 23, 32, 0.86);
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
      }

      .start-screen__title {
        margin: 0 0 0.65rem;
        font-size: 1.5rem;
        font-weight: 800;
      }

      .start-screen__text {
        margin: 0 0 1.1rem;
        line-height: 1.5;
        color: rgba(244, 247, 251, 0.82);
      }

      .start-screen__button {
        border: 0;
        padding: 0.8rem 1.3rem;
        border-radius: 999px;
        font: inherit;
        font-weight: 700;
        color: #0b1320;
        background: linear-gradient(180deg, #f8fbff 0%, #bcd4ff 100%);
        cursor: pointer;
      }

      .start-screen__button:hover {
        transform: translateY(-1px);
      }

      .start-screen__button:active {
        transform: translateY(0);
      }

      .start-screen__hint {
        margin: 0.6rem 0 0;
        font-size: 0.85rem;
        color: rgba(244, 247, 251, 0.55);
      }

      .map-overlay {
        position: fixed;
        inset: 0;
        display: grid;
        place-items: center;
        padding: 1.5rem;
        background: rgba(8, 12, 18, 0.8);
        backdrop-filter: blur(10px);
        z-index: 99999;
        pointer-events: auto;
      }

      .map-overlay[hidden] {
        display: none;
      }

      .map-overlay__panel {
        width: min(100%, 46rem);
        padding: 1rem;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 18px;
        background: rgba(15, 23, 32, 0.9);
        box-shadow: 0 24px 70px rgba(0, 0, 0, 0.4);
        pointer-events: auto;
      }

      .map-overlay__title {
        margin: 0 0 0.3rem;
        font-size: 1.2rem;
        font-weight: 800;
      }

      .map-overlay__text {
        margin: 0 0 0.8rem;
        color: rgba(244, 247, 251, 0.82);
        line-height: 1.45;
      }

      .map-overlay__scale-key {
        margin: 0 0 0.65rem;
        padding: 0.5rem 0.65rem;
        font-size: 0.82rem;
        line-height: 1.4;
        color: rgba(210, 225, 245, 0.9);
        background: rgba(8, 14, 22, 0.65);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 10px;
      }

      .map-overlay__canvas {
        width: 100%;
        aspect-ratio: 1 / 1;
        border-radius: 14px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: linear-gradient(180deg, #16202e 0%, #101720 100%);
        cursor: crosshair;
        touch-action: none;
        pointer-events: auto;
      }

      .map-overlay__footer {
        margin-top: 0.7rem;
        font-size: 0.88rem;
        color: rgba(244, 247, 251, 0.75);
      }

      .hud__radio-signal {
        position: absolute;
        left: 50%;
        bottom: 4rem;
        transform: translateX(-50%);
        padding: 0.5rem 1rem;
        border-radius: 8px;
        background: rgba(15, 23, 32, 0.85);
        border: 1px solid rgba(100, 180, 255, 0.35);
        font-size: 0.85rem;
        color: rgba(150, 200, 255, 0.95);
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .hud__radio-signal-dot {
        width: 6px;
        height: 6px;
        background: #4cc0ff;
        border-radius: 50%;
        animation: radio-pulse 1s ease-in-out infinite;
      }

      @keyframes radio-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
      }

      .hud--waiting .hud__status,
      .hud--waiting .hud__crosshair,
      .hud--waiting .hud__score,
      .hud--waiting .hud__trajectory,
      .hud--waiting .hud__radio-signal {
        display: none;
      }
    </style>
    <script type="importmap">
      {
        "imports": {
          "three": "https://cdn.jsdelivr.net/npm/three@0.183.2/build/three.module.js",
          "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.183.2/examples/jsm/"
        }
      }
    </script>
  </head>
  <body>
    <div id="app">
      <div class="loading-screen" id="loading-screen">
        <h2 class="loading-screen__title">Loading mortar game</h2>
        <div class="loading-screen__bar-wrap">
          <div class="loading-screen__bar" id="loading-bar"></div>
        </div>
        <p class="loading-screen__text" id="loading-text">Initializing...</p>
      </div>
      <div class="start-screen" id="start-screen" hidden>
        <div class="start-screen__panel">
          <h1 class="start-screen__title">Player Camera Demo</h1>
          <p class="start-screen__text">
            Press start to enter the map.<br />
            <strong>WASD</strong> move — <strong>first time only</strong>: <strong>E</strong> at the <strong>radio crate</strong> spawns the floating <strong>COLLECT</strong> ring; <strong>E</strong> again to pick it up. After that, <strong>2</strong> holds/stows the radio on you (no ring). <strong>M</strong> map / carpet bomb, <strong>C</strong> toggles compass HUD (map always shows north rose), <strong>B</strong> binoculars, <strong>1–3</strong> zoom while scoped, <strong>Z</strong> camera.
          </p>
          <button class="start-screen__button" id="start-button" type="button">Start</button>
          <p class="start-screen__hint">or press Enter</p>
        </div>
      </div>
      <div class="map-overlay" id="map-overlay" hidden>
        <div class="map-overlay__panel">
          <h2 class="map-overlay__title">Mortar aiming map</h2>
          <p class="map-overlay__text" id="map-instructions">
            Press <strong>M</strong> or <strong>Esc</strong> to close. <strong>North-up</strong> map — corner rose is <strong>true north</strong> with <strong>0–360°</strong> ticks. <strong>C</strong> toggles the <strong>HUD</strong> compass while playing. <strong>HE / HS</strong>: aim line, <strong>Q</strong> for half set square. When placed: <strong>drag on the map</strong> (not on the tool) <strong>left ↔ right</strong> to rotate; <strong>drag on the tool</strong> to move. <strong>Q</strong> → click re-aims (clears tool) → <strong>Q</strong> → click places again. <strong>Plot board</strong> + stopwatch. <strong>Double-click</strong> clears. <strong>Tracking</strong>: click target.
          </p>
          <p class="map-overlay__scale-key" id="map-scale-key"></p>
          <canvas class="map-overlay__canvas" id="map-canvas" width="720" height="720"></canvas>
          <div class="map-overlay__footer" id="map-footer">No target selected</div>
        </div>
      </div>
      <div class="hud hud--waiting" id="hud">
        <div class="hud__trajectory" id="trajectory" hidden>
          <span class="hud__trajectory-label">Mortar trajectory</span>
          <span id="trajectory-text">Range: 0 ft | Arc: 0 deg</span>
        </div>
        <div class="hud__score" id="score">Score: 0 | Towns: 0/0</div>
        <div class="hud__crosshair" aria-hidden="true"></div>
        <div class="hud__status" id="status">Loading scene...</div>
        <div class="hud__binocular-zoom" id="binocular-zoom" hidden>10×</div>
        <div class="hud__radio-signal" id="radio-signal" hidden>
          <span class="hud__radio-signal-dot"></span>
          Sending dispatch:
        </div>
      </div>
      <div id="binocular-overlay" class="binocular-overlay" hidden aria-hidden="true">
        <div class="binocular-overlay__lens binocular-overlay__lens--left"></div>
        <div class="binocular-overlay__bridge"></div>
        <div class="binocular-overlay__lens binocular-overlay__lens--right"></div>
      </div>
      <div id="compass-hud" class="compass-hud" hidden aria-hidden="true">
        <p class="compass-hud__hint">Compass (C) — north = map +Z</p>
        <div class="compass-hud__circle">
          <div class="compass-hud__lubber" aria-hidden="true"></div>
          <div class="compass-hud__dial" id="compass-dial">
            <span class="compass-hud__cardinal compass-hud__cardinal--n" style="--cmp-a: 0deg">N</span>
            <span class="compass-hud__cardinal" style="--cmp-a: 90deg">E</span>
            <span class="compass-hud__cardinal" style="--cmp-a: 180deg">S</span>
            <span class="compass-hud__cardinal" style="--cmp-a: 270deg">W</span>
          </div>
        </div>
        <div class="compass-hud__readout" id="compass-degrees">000°</div>
        <div class="compass-hud__readout compass-hud__readout--tube" id="compass-tube-brg" hidden>Tube 000°</div>
      </div>
    </div>
    <script>
      window.addEventListener(
        "error",
        function (e) {
          if (e.target && e.target !== window) return;
          var t = document.getElementById("loading-text");
          var ls = document.getElementById("loading-screen");
          var ss = document.getElementById("start-screen");
          if (t && ls && !ls.hidden && ss && ss.hidden) {
            t.textContent =
              "Game script failed to run. Press F12 → Console for the error. If you opened this file from disk (file://), try a local server (e.g. Live Server) so Three.js can load from the CDN.";
          }
        },
        true,
      );
      window.addEventListener("unhandledrejection", function () {
        var t = document.getElementById("loading-text");
        var ls = document.getElementById("loading-screen");
        var ss = document.getElementById("start-screen");
        if (t && ls && !ls.hidden && ss && ss.hidden) {
          t.textContent =
            "Could not load game code (often blocked network or imports). Check internet, disable strict blockers, or serve this folder over http:// (not file://). F12 → Console for details.";
        }
      });
      setTimeout(function () {
        var t = document.getElementById("loading-text");
        var ls = document.getElementById("loading-screen");
        var ss = document.getElementById("start-screen");
        if (t && ls && !ls.hidden && ss && ss.hidden && t.textContent === "Initializing...") {
          t.textContent =
            "Still stuck here? The game needs to download Three.js from the internet. Check connection, or use a simple local HTTP server instead of opening the file directly.";
        }
      }, 10000);
    </script>
    <script type="module">
import * as THREE from "three";
import { GLTFLoader } from "three/addons/loaders/GLTFLoader.js";

const MOVE_SPEED = 6;
const LOOK_SENSITIVITY = 0.0024;
const MAX_PITCH = Math.PI / 2 - 0.08;
const INTERACT_DISTANCE = 2.6;
const SHELL_PICKUP_DISTANCE = 5.2;
const MORTAR_LAUNCH_SPEED = 328;
/** Doubles ballistic range vs baseline (R ∝ v²/g → scale v by √2). */
const BALLISTIC_RANGE_SCALE = 2;
const SHELL_GRAVITY = 9.2;
const CAMERA_SHAKE_DURATION = 4.8;
const CAMERA_SHAKE_GLOBAL_FLOOR = 0.7125;
const CAMERA_SHAKE_POWER_SCALE = 1.6744;
/** Ground-distance shock propagation (~ft/s); camera shake + terrain rings use this speed. */
const SHOCKWAVE_SPEED = 1125;

const SHOCKWAVE_TERRAIN_PROFILES = {
