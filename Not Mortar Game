    const cm = exp.carpetSwMul ?? 1;
    exp.core.scale.setScalar(1 + progress * 8 * cm);
    exp.core.material.opacity = 0.9 * fade;
    exp.halo.scale.setScalar(1 + progress * 6 * cm);
    exp.halo.material.opacity = 0.6 * fade;
    exp.shockwave.scale.setScalar(1 + progress * 15 * cm);
    exp.shockwave.material.opacity = 0.8 * fade;
    exp.scorch.scale.setScalar(1 + progress * 4 * cm);
    exp.scorch.material.opacity = 0.6 * fade;
