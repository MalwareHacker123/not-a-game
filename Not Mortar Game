function isLookingAtMortar() {
  if (!mortarRoot) {
    return false;
  }

  const mortarPosition = new THREE.Vector3();
  const cameraPosition = new THREE.Vector3();
  const cameraForward = new THREE.Vector3(0, 0, -1);
  mortarRoot.getWorldPosition(mortarPosition);
  camera.getWorldPosition(cameraPosition);
  cameraForward.applyQuaternion(camera.getWorldQuaternion(new THREE.Quaternion()));

  const toMortar = mortarPosition.sub(cameraPosition);
  const distance = toMortar.length();
  if (distance > 45) {
    return false;
  }

  toMortar.normalize();
  return cameraForward.normalize().dot(toMortar) > 0.8;
}

/**
 * Horizontal compass bearing of the tube (0–360°, 0° = world +Z / map north), clockwise — matches player compass readout.
 */
function getMortarTubeAzimuthDegrees() {
  if (!mortarTube || !mortarRoot) {
    return 0;
  }

  const shellDefinition = getCurrentShellDefinition() ?? SHELL_TYPES.highExplosive;
  const start = mortarTube.localToWorld(new THREE.Vector3(0, 0.72, 0));

  if (shellDefinition.requiresMapTarget && trackingTarget) {
    const dx = trackingTarget.x - start.x;
    const dz = trackingTarget.z - start.z;
    let deg = THREE.MathUtils.radToDeg(Math.atan2(dx, dz));
    if (deg < 0) {
      deg += 360;
    }
    return deg;
  }

  if (shellDefinition.requiresMapTarget && !trackingTarget) {
    const fwd = new THREE.Vector3(0, 0, -1).applyAxisAngle(new THREE.Vector3(0, 1, 0), mortarYaw);
    let deg = THREE.MathUtils.radToDeg(Math.atan2(fwd.x, fwd.z));
    if (deg < 0) {
      deg += 360;
    }
    return deg;
  }

  const direction = new THREE.Vector3(0, 1, 0)
    .applyQuaternion(mortarTube.getWorldQuaternion(new THREE.Quaternion()))
    .normalize();
  const horizLen = Math.hypot(direction.x, direction.z);
  if (horizLen < 1e-8) {
    const fwd = new THREE.Vector3(0, 0, -1).applyAxisAngle(new THREE.Vector3(0, 1, 0), mortarYaw);
    let deg = THREE.MathUtils.radToDeg(Math.atan2(fwd.x, fwd.z));
    if (deg < 0) {
      deg += 360;
    }
    return deg;
  }
  let deg = THREE.MathUtils.radToDeg(Math.atan2(direction.x, direction.z));
  if (deg < 0) {
    deg += 360;
  }
  return deg;
}

function getMortarTrajectoryData() {
  if (!mortarTube) {
    return null;
  }

  const shellDefinition = getCurrentShellDefinition() ?? SHELL_TYPES.highExplosive;
  const start = mortarTube.localToWorld(new THREE.Vector3(0, 0.72, 0));
  const azimuthDeg = getMortarTubeAzimuthDegrees();

  if (shellDefinition.requiresMapTarget && !trackingTarget) {
    return {
      points: [],
      landingPoint: start.clone(),
      range: 0,
      angleDeg: THREE.MathUtils.radToDeg(mortarPitch),
      azimuthDeg,
      shellDefinition,
      needsMapTarget: true,
    };
  }

  if (shellDefinition.requiresMapTarget && trackingTarget) {
    const targetPoint = new THREE.Vector3(trackingTarget.x, 0.1, trackingTarget.z);
    const points = [];
    for (let index = 0; index <= 40; index += 1) {
      const t = index / 40;
      const point = start.clone().lerp(targetPoint, t);
      point.y += Math.sin(t * Math.PI) * 90;
      points.push(point);
    }
    return {
      points,
      landingPoint: targetPoint,
      range: new THREE.Vector2(targetPoint.x - start.x, targetPoint.z - start.z).length(),
      angleDeg: THREE.MathUtils.radToDeg(mortarPitch),
      azimuthDeg,
      shellDefinition,
    };
  }

  const direction = new THREE.Vector3(0, 1, 0)
    .applyQuaternion(mortarTube.getWorldQuaternion(new THREE.Quaternion()))
    .normalize();
  const velocity = direction.clone().multiplyScalar(ballisticMuzzleSpeed(shellDefinition));
  const points = [start.clone()];

  const currentPosition = start.clone();
  const currentVelocity = velocity.clone();
  let landingPoint = start.clone();
  const step = 0.12;

  for (let index = 0; index < 140; index += 1) {
    const previousPosition = currentPosition.clone();
    currentVelocity.y -= SHELL_GRAVITY * step;
    currentPosition.addScaledVector(currentVelocity, step);

    if (currentPosition.y <= 0.1) {
      const t = (previousPosition.y - 0.1) / (previousPosition.y - 0.1 - (currentPosition.y - 0.1));
      landingPoint = previousPosition.clone().lerp(currentPosition, THREE.MathUtils.clamp(t, 0, 1));
      landingPoint.y = 0.1;
      points.push(landingPoint.clone());
      break;
    }

    points.push(currentPosition.clone());
    landingPoint = currentPosition.clone();
  }

  const range = new THREE.Vector2(landingPoint.x - start.x, landingPoint.z - start.z).length();

  return {
    points,
    landingPoint,
    range,
    angleDeg: THREE.MathUtils.radToDeg(mortarPitch),
    azimuthDeg,
    shellDefinition,
  };
}

function updateTrajectoryPreview() {
  const shouldShow =
    gameStarted &&
    !mapOpen &&
    !trackedProjectile &&
    cinematicImpactTimer <= 0 &&
    !activeTownReplay &&
    (mortarRotateMode || isLookingAtMortar());

  if (!shouldShow) {
    trajectoryElement.hidden = true;
    if (trajectoryLine) {
      trajectoryLine.visible = false;
    }
    if (trajectoryMarker) {
      trajectoryMarker.visible = false;
    }
    return;
  }

  const trajectoryData = getMortarTrajectoryData();
  if (!trajectoryData) {
    return;
  }

  trajectoryElement.hidden = false;
  if (trajectoryData.needsMapTarget) {
    trajectoryTextElement.textContent = `${trajectoryData.shellDefinition.shortName}: press M to choose target`;
    trajectoryLine.visible = false;
    trajectoryMarker.visible = false;
    return;
  }

  trajectoryTextElement.textContent = `${trajectoryData.shellDefinition.shortName}: ${Math.round(trajectoryData.range)} ft | Brg ${String(Math.round(trajectoryData.azimuthDeg)).padStart(3, "0")}° | Arc ${Math.round(trajectoryData.angleDeg)}°`;

  const showWorldArc = trajectoryData.shellDefinition.requiresMapTarget;
  if (!showWorldArc) {
    trajectoryLine.visible = false;
    trajectoryMarker.visible = false;
    return;
  }

  const pts = trajectoryData.points;
  if (pts.length >= 2) {
    const prevGeom = trajectoryLine.geometry;
    trajectoryLine.geometry = new THREE.BufferGeometry().setFromPoints(pts);
    prevGeom.dispose();
    trajectoryLine.visible = true;
  } else {
    trajectoryLine.visible = false;
  }

  trajectoryMarker.position.copy(trajectoryData.landingPoint);
  trajectoryMarker.position.y = 0.08;
  trajectoryMarker.visible = true;
}

function applyCameraTransform() {
  const baseOffset = getBaseCameraOffset();
  const shakePower = cameraShakeAmount * CAMERA_SHAKE_POWER_SCALE;
  const offsetX = (Math.random() - 0.5) * 1.3 * shakePower;
  const offsetY = (Math.random() - 0.5) * 0.95 * shakePower;
  const offsetZ = (Math.random() - 0.5) * 1.15 * shakePower;
  camera.position.set(baseOffset.x + offsetX, baseOffset.y + offsetY, baseOffset.z + offsetZ);
  camera.rotation.z = (Math.random() - 0.5) * 0.24 * shakePower;
}

function setBirdsEyeView(active) {
  if (birdsEyeView === active) return;
  birdsEyeView = active;

  if (!birdsEyeView) {
    if (birdsEyeSavedParent) {
      birdsEyeSavedParent.add(camera);
      camera.position.copy(birdsEyeSavedLocalPos);
      camera.rotation.copy(birdsEyeSavedLocalRot);
    }
    birdsEyeSavedParent = null;
    return;
  }

  birdsEyeSavedParent = camera.parent ?? null;
  birdsEyeSavedLocalPos.copy(camera.position);
  birdsEyeSavedLocalRot.copy(camera.rotation);
  scene.add(camera);

  // Birds-eye is like a map camera: free cursor.
  try {
    document.exitPointerLock?.();
  } catch {
    // ignore
  }
}

function applyBirdsEyeCameraTransform(delta) {
  const target = new THREE.Vector3();
  player.getWorldPosition(target);

  const desired = new THREE.Vector3(target.x, birdsEyeHeight, target.z);
  const k = 1 - Math.exp(-birdsEyeFollowLerp * Math.max(0, delta));
  camera.position.lerp(desired, k);

  // North-up (map north is +Z). With camera looking down, "up" controls which way is north.
  camera.up.set(0, 0, 1);
  camera.lookAt(target.x, 0, target.z);
  camera.rotation.z = 0;
}

/** Shake vs ground distance (world units ≈ ft): 100 → 10×, 10_000 → 0.01 via m = 10000·d^-1.5. */
function getShockwaveDistanceMultiplier(distance) {
  const d = Math.max(1, distance);
  const m = 10000 * Math.pow(d, -1.5);
  return THREE.MathUtils.clamp(m, 0, 10);
}

function applyCameraShakeImpulse(sourcePosition, strength = 1) {
  const playerPosition = new THREE.Vector3();
  player.getWorldPosition(playerPosition);
  const blast = sourcePosition.clone();
  playerPosition.y = 0;
  blast.y = 0;
  const distance = playerPosition.distanceTo(blast);
  const distanceMultiplier = getShockwaveDistanceMultiplier(distance);
  const baseImpulse = CAMERA_SHAKE_GLOBAL_FLOOR * strength;
  const shakeImpulse = baseImpulse * distanceMultiplier;
  cameraShakeAmount = Math.min(4.15, Math.max(cameraShakeAmount, shakeImpulse));
  cameraShakeTimer = Math.max(cameraShakeTimer, CAMERA_SHAKE_DURATION * strength * 1.08);
}

function scheduleCameraShake(sourcePosition, strength = 1) {
  const playerPosition = new THREE.Vector3();
  player.getWorldPosition(playerPosition);
  const blast = sourcePosition.clone();
  playerPosition.y = 0;
  blast.y = 0;
  const distance = Math.max(0, playerPosition.distanceTo(blast));
  const delay = distance / SHOCKWAVE_SPEED;
  pendingCameraShakes.push({
    remaining: delay,
    position: sourcePosition.clone(),
    strength,
  });
}

function processPendingCameraShakes(delta) {
  for (let i = pendingCameraShakes.length - 1; i >= 0; i -= 1) {
    const p = pendingCameraShakes[i];
    p.remaining -= delta;
    if (p.remaining <= 0) {
      const playerPosition = new THREE.Vector3();
      player.getWorldPosition(playerPosition);
      const blast = p.position.clone();
      playerPosition.y = 0;
      blast.y = 0;
      const distance = Math.max(0, playerPosition.distanceTo(blast));
      const hitStrength = p.strength * 1.62;
      applyCameraShakeImpulse(p.position, hitStrength);
      const tailLen = distance / SHOCKWAVE_SPEED;
      if (tailLen > 0.02) {
        shockwaveTailTimer = Math.max(shockwaveTailTimer, tailLen);
        shockwaveTailDuration = Math.max(shockwaveTailDuration, tailLen);
        shockwaveTailStrength = Math.max(shockwaveTailStrength, hitStrength);
      }
      pendingCameraShakes.splice(i, 1);
    }
  }
}

/** Subtle camera rumble while the ground shock is still traveling toward the player. */
function applyShockwaveApproachRumble() {
  const p = new THREE.Vector3();
  player.getWorldPosition(p);
  p.y = 0;
  let subtle = 0;
  for (const w of activeTerrainShockwaves) {
    const dist = Math.hypot(p.x - w.origin.x, p.z - w.origin.z);
    const r = w.age * w.speed;
    const ahead = dist - r;
    if (ahead > 0 && ahead < 1650) {
      const t = 1 - ahead / 1650;
      subtle = Math.max(subtle, t * t * 0.13 * Math.sqrt(w.intensity));
    }
  }
  if (subtle > 0) {
    cameraShakeAmount = Math.max(cameraShakeAmount, subtle);
  }
}

/** Light rumble after the shock front hits, until the delayed blast-wind sound catches up. */
function applyShockwaveTailRumble(delta) {
  if (shockwaveTailTimer > 0) {
    shockwaveTailTimer -= delta;
    const u =
      shockwaveTailDuration > 1e-4
        ? THREE.MathUtils.clamp(shockwaveTailTimer / shockwaveTailDuration, 0, 1)
        : 0;
    const pulse = 1 + 0.32 * Math.sin(shockwaveOscTime * 0.29);
    const base =
      0.11 *
      u *
      pulse *
      THREE.MathUtils.clamp(shockwaveTailStrength * 0.36, 0.11, 1.05);
    cameraShakeAmount = Math.max(cameraShakeAmount, base);
  }
  if (shockwaveTailTimer <= 0 && shockwaveTailDuration > 0) {
    shockwaveTailDuration = 0;
    shockwaveTailStrength = 0;
  }
}

function registerTerrainShockwave(epicenter, intensity = 1, shellKind = "highExplosive") {
  const prof = SHOCKWAVE_TERRAIN_PROFILES[shellKind] ?? SHOCKWAVE_TERRAIN_PROFILES.highExplosive;
  const origin = epicenter.clone();
  origin.y = 0;
  const ringMat = new THREE.MeshBasicMaterial({
    color: prof.color,
    transparent: true,
    opacity: 0.2 * THREE.MathUtils.clamp(intensity, 0.2, 2.5) * prof.opacityMul,
    side: THREE.DoubleSide,
    depthWrite: false,
  });
  const ringMesh = new THREE.Mesh(new THREE.RingGeometry(prof.ringInner, prof.ringOuter, prof.seg), ringMat);
  ringMesh.rotation.x = -Math.PI / 2;
  ringMesh.position.set(epicenter.x, 0.06, epicenter.z);
  ringMesh.renderOrder = 2;
  scene.add(ringMesh);

  activeTerrainShockwaves.push({
    origin,
    age: 0,
    speed: SHOCKWAVE_SPEED * prof.speedMul,
    intensity: THREE.MathUtils.clamp(intensity, 0.25, 2.8),
    ringMesh,
    maxRadius: MAP_WORLD_EXTENT * 2.35,
    swMapRings: prof.mapRings,
    swMapGap: prof.mapGap,
    swRgb: prof.mapRgb,
    swWobbleMul: prof.wobbleMul,
    swOpacityMul: prof.opacityMul,
  });
}

function drawMapShockwaveRipples(ctx, size) {
  const H = getMapHalfExtentFt();
  const pxPerWorld = size / (2 * H);
  for (const w of activeTerrainShockwaves) {
    const r = w.age * w.speed;
    const fade = THREE.MathUtils.clamp(1 - r / (w.maxRadius * 0.92), 0, 1);
    if (fade < 0.02) continue;
    const center = worldToMap(w.origin.x, w.origin.z);
    const nRings = w.swMapRings ?? 4;
    const gap = w.swMapGap ?? 220;
    const [cr, cg, cb] = w.swRgb ?? [160, 210, 255];
    for (let ring = 0; ring < nRings; ring += 1) {
      const rr = r - ring * gap;
      if (rr < 25) continue;
      const radPx = rr * pxPerWorld;
      if (radPx > size * 0.72) continue;
      const a = 0.42 * fade * (1 - ring * 0.14) * Math.min(1, w.intensity) * (w.swOpacityMul ?? 1);
      ctx.strokeStyle = `rgba(${cr},${cg},${cb},${a})`;
      ctx.lineWidth = ring === 0 ? 2.2 : 1.6;
      ctx.beginPath();
      ctx.arc(center.x, center.y, radPx, 0, Math.PI * 2);
      ctx.stroke();
    }
  }
}

function updateTownShockwaveWobble() {
  for (const town of targetTowns) {
    if (town.destroyed) continue;
    for (const st of town.structures) {
      if (st.destroyed) continue;
      let dx = 0;
      let dz = 0;
      let ry = 0;
      for (const w of activeTerrainShockwaves) {
        const r = w.age * w.speed;
        const d = Math.hypot(st.position.x - w.origin.x, st.position.z - w.origin.z);
        const band = 110 * w.intensity * (w.swWobbleMul ?? 1);
        const distToFront = Math.abs(d - r);
        if (distToFront < band) {
          const waveAmp = Math.pow(1 - distToFront / band, 2);
          const farFall = 1 / (1 + d * 0.00038);
          const mag = waveAmp * farFall * 0.5 * w.intensity;
          const ang = shockwaveOscTime + d * 0.07;
          dx += Math.cos(ang) * mag * 2.4;
          dz += Math.sin(ang * 1.07) * mag * 2.4;
          ry += Math.sin(ang * 1.2) * mag * 0.055;
        }
      }
      st.building.position.set(st.position.x + dx, st.position.y, st.position.z + dz);
      st.building.rotation.y = ry;
      if (st.roof && st.roofPosition) {
        st.roof.position.set(st.roofPosition.x + dx, st.roofPosition.y, st.roofPosition.z + dz);
        st.roof.rotation.y = ry;
        st.roof.rotation.z = st.initialRoofRotZ;
      }
    }
  }
}

function updateTerrainShockwaves(delta) {
  processPendingCameraShakes(delta);
  shockwaveOscTime += delta * 38;
  applyShockwaveApproachRumble();
  applyShockwaveTailRumble(delta);
  for (let i = activeTerrainShockwaves.length - 1; i >= 0; i -= 1) {
    const w = activeTerrainShockwaves[i];
    w.age += delta;
    const r = w.age * w.speed;
    if (w.ringMesh) {
      w.ringMesh.scale.setScalar(Math.max(20, r));
      const fade = THREE.MathUtils.clamp(1 - r / (w.maxRadius * 0.88), 0, 1);
      w.ringMesh.material.opacity = 0.2 * w.intensity * fade * (w.swOpacityMul ?? 1);
    }
    if (r > w.maxRadius) {
      if (w.ringMesh) {
        scene.remove(w.ringMesh);
        w.ringMesh.geometry.dispose();
        w.ringMesh.material.dispose();
      }
      activeTerrainShockwaves.splice(i, 1);
    }
  }
  updateTownShockwaveWobble();
  if (mapOpen && activeTerrainShockwaves.length > 0) {
    renderMap();
  }
}

function startProjectileTracking(projectile) {
  if (!projectile) {
    return;
  }

  if (mapOpen) closeMap();

  viewBeforeProjectileTrack = currentView;
  currentView = "third";
  mortarRotateMode = false;
  trackedProjectile = projectile;
  cinematicImpactTimer = 0;
  avatarRoot.visible = true;

  if (camera.parent !== scene) {
    scene.attach(camera);
  }
}

function updateProjectileTracking(delta) {
  if (trackedProjectile) {
    const projectilePosition = trackedProjectile.position.clone();
    const projectileVelocity =
      activeProjectiles.find((projectile) => projectile.mesh === trackedProjectile)?.velocity ?? new THREE.Vector3(0, 1, 0);
    const behindOffset = projectileVelocity.clone().normalize().multiplyScalar(-28);
    behindOffset.y += 11;
    const shakePower = cameraShakeAmount * cameraShakeAmount;
    const shakeOffset = new THREE.Vector3(
      (Math.random() - 0.5) * 0.9 * shakePower,
      (Math.random() - 0.5) * 0.7 * shakePower,
      (Math.random() - 0.5) * 0.9 * shakePower,
    );
    camera.position.copy(projectilePosition).add(behindOffset).add(shakeOffset);
    camera.lookAt(projectilePosition.clone().add(projectileVelocity.clone().multiplyScalar(0.12)));
    camera.rotation.z += (Math.random() - 0.5) * 0.08 * shakePower;
    return;
  }

  if (cinematicImpactTimer > 0 && cinematicImpactFocus) {
    cinematicImpactTimer = Math.max(0, cinematicImpactTimer - delta);
    const offset = new THREE.Vector3(-24, 14, 18);
    const shakePower = cameraShakeAmount * cameraShakeAmount;
    offset.x += (Math.random() - 0.5) * 1.2 * shakePower;
    offset.y += (Math.random() - 0.5) * 0.9 * shakePower;
    offset.z += (Math.random() - 0.5) * 1.2 * shakePower;
    camera.position.copy(cinematicImpactFocus).add(offset);
    camera.lookAt(cinematicImpactFocus);
    camera.rotation.z += (Math.random() - 0.5) * 0.1 * shakePower;
    if (cinematicImpactTimer === 0) {
      endProjectileTracking();
    }
  }
}

function endProjectileTracking() {
  trackedProjectile = null;
  cinematicImpactTimer = 0;
  cinematicImpactFocus = null;
  mortarRotateMode = false;
  currentView = viewBeforeProjectileTrack;

  if (camera.parent !== cameraRig) {
    cameraRig.attach(camera);
  }

  camera.rotation.set(0, 0, 0);
  updateCameraMode();
}

function handleInteraction() {
  if (radioPickupGroup && isNearRadioPickup()) {
    collectRadioFromGround();
    return;
  }
  if (!hasBinoculars && isNearObject(binocularsCrateObject)) {
    hasBinoculars = true;
    GameAudio.playShellClack(0.42);
    updateStatus();
    return;
  }
  if (heldRadio) return;
  if (!hasRadio && isNearObject(radioCrateObject)) {
    if (!radioIntroComplete) {
      if (!radioAwaitingGroundPickup) {
        spawnRadioGroundPickup({ introRise: true });
        radioAwaitingGroundPickup = true;
        GameAudio.playShellClack(0.16);
      }
    } else {
      hasRadio = true;
      GameAudio.playRadioPickup();
    }
    updateStatus();
    return;
  }
  if (loadedShell && isNearMortar()) {
    fireLoadedShell();
    return;
  }

  if (heldShell && !loadedShell && isNearMortar()) {
    insertHeldShellIntoMortar();
    return;
  }

  if (!heldShell && !loadedShell) {
    const shell = getNearestAvailableShell();
    if (shell) {
      pickUpShell(shell);
    }
  }
}

function isNearShell() {
  return Boolean(getNearestAvailableShell());
}

function isNearMortar() {
  return isNearObject(mortarRoot);
}

function getNearestAvailableShell() {
  let nearestShell = null;
  let nearestDistance = SHELL_PICKUP_DISTANCE;

  for (const shell of looseShells) {
    if (shell.userData.state !== "available") {
      continue;
    }

    const distance = getHorizontalDistanceToObject(shell);
    if (distance <= nearestDistance) {
      nearestDistance = distance;
      nearestShell = shell;
    }
  }

  return nearestShell;
}

function isNearObject(object) {
  if (!object) return false;
  return getHorizontalDistanceToObject(object) <= INTERACT_DISTANCE;
}

function getHorizontalDistanceToObject(object) {
  if (!object) {
    return Number.POSITIVE_INFINITY;
  }

  const playerPosition = new THREE.Vector3();
  const objectPosition = new THREE.Vector3();
  player.getWorldPosition(playerPosition);
  object.getWorldPosition(objectPosition);
  playerPosition.y = 0;
  objectPosition.y = 0;
  return playerPosition.distanceTo(objectPosition);
}

function putBackShell() {
  if (!heldShell || !shellCrateRoot) return;
  const shell = heldShell;
  heldShell = null;
  if (shell.parent) shell.parent.remove(shell);
  shellCrateRoot.add(shell);
  shell.userData.state = "available";
  shell.position.set((Math.random() - 0.5) * 0.4, 0.38, (Math.random() - 0.5) * 0.5);
  shell.rotation.order = "YXZ";
  shell.rotation.set(0.1 + Math.random() * 0.15, Math.random() * Math.PI * 2, 0.3 + Math.random() * 0.12);
  refreshHeldShellAnchor();
  GameAudio.playShellClack(0.2);
}

function pickUpShell(shell) {
  if (!shell) {
    return;
  }

  heldShell = shell;
  shell.userData.state = "held";
  if (getShellDefinition(shell).id !== "tracking") {
    trackingTarget = null;
  }
  refreshHeldShellAnchor();
  updateStatus();
  GameAudio.playShellClack(0.36);
}

function refreshHeldShellAnchor() {
  if (!heldShell) {
    return;
  }

  const targetAnchor = currentView === "first" ? firstPersonCarryAnchor : thirdPersonCarryAnchor;
  targetAnchor.add(heldShell);
  heldShell.position.set(0, 0, 0);
  heldShell.rotation.set(0, 0, 0);
}

function insertHeldShellIntoMortar() {
  if (!heldShell || !mortarTube) {
    return;
  }

  const shellDefinition = getShellDefinition(heldShell);
  if (shellDefinition.requiresMapTarget && !trackingTarget) {
    updateStatus();
    return;
  }

  loadedShell = heldShell;
  heldShell = null;
  loadedShell.userData.state = "loaded";
  mortarTube.add(loadedShell);
  loadedShell.position.set(0, 0.22, 0);
  loadedShell.rotation.set(0, 0, 0);
  updateStatus();
  GameAudio.playShellLoad();
}

function fireLoadedShell() {
  if (!loadedShell || !mortarTube) {
    return;
  }

  const shellDefinition = getShellDefinition(loadedShell);
  const projectile = loadedShell;
  const launchPosition = mortarTube.localToWorld(new THREE.Vector3(0, 0.72, 0));
  const launchDirection = new THREE.Vector3(0, 1, 0)
    .applyQuaternion(mortarTube.getWorldQuaternion(new THREE.Quaternion()))
    .normalize();

  if (shellDefinition.requiresMapTarget && !trackingTarget) {
    updateStatus();
    return;
  }

  loadedShell = null;
  projectile.userData.state = "flying";
  projectile.userData.shellType = shellDefinition.id;
  scene.add(projectile);
  projectile.position.copy(launchPosition);

  let projectileData;
  if (shellDefinition.requiresMapTarget) {
    const targetPoint = new THREE.Vector3(trackingTarget.x, 0.1, trackingTarget.z);
    projectile.position.copy(launchPosition);
    projectileData = {
      mesh: projectile,
      type: "tracking",
      shellDefinition,
      start: launchPosition.clone(),
      target: targetPoint,
      progress: 0,
      duration: Math.max(2.2, launchPosition.distanceTo(targetPoint) / 170),
    };
  } else {
    const inaccuracyRadians = THREE.MathUtils.degToRad(shellDefinition.inaccuracyDegrees);
    const inaccurateDirection = launchDirection
      .clone()
      .applyAxisAngle(new THREE.Vector3(0, 1, 0), (Math.random() - 0.5) * inaccuracyRadians)
      .applyAxisAngle(new THREE.Vector3(1, 0, 0), (Math.random() - 0.5) * inaccuracyRadians)
      .normalize();

    projectile.quaternion.copy(new THREE.Quaternion().setFromUnitVectors(new THREE.Vector3(0, 1, 0), inaccurateDirection));
    projectileData = {
      mesh: projectile,
      type: "ballistic",
      shellDefinition,
      velocity: inaccurateDirection.multiplyScalar(ballisticMuzzleSpeed(shellDefinition)),
      age: 0,
    };
  }

  activeProjectiles.push(projectileData);

  GameAudio.playMortarLaunch(launchPosition);
  startProjectileTracking(projectile);
  updateStatus();
}

function createCrater(position, craterScale = 1) {
  const craterRoot = new THREE.Group();
  craterRoot.position.copy(position);
  scene.add(craterRoot);

  const craterWall = new THREE.Mesh(
    new THREE.CylinderGeometry(26 * craterScale, 9.5 * craterScale, 9.5 * craterScale, 60, 1, true),
    new THREE.MeshStandardMaterial({
      color: 0x2b211c,
      roughness: 1,
      metalness: 0,
      side: THREE.DoubleSide,
    }),
  );
  craterWall.position.y = -4.35 * craterScale;
  craterRoot.add(craterWall);

  const craterFloor = new THREE.Mesh(
    new THREE.CircleGeometry(9.8 * craterScale, 60),
    new THREE.MeshStandardMaterial({
      color: 0x120e0c,
      roughness: 1,
      metalness: 0,
    }),
  );
  craterFloor.rotation.x = -Math.PI / 2;
  craterFloor.position.y = -8.8 * craterScale;
  craterRoot.add(craterFloor);

  const shatteredGround = new THREE.Mesh(
    new THREE.RingGeometry(10.2 * craterScale, 30 * craterScale, 84),
    new THREE.MeshStandardMaterial({
      color: 0x2f2622,
      roughness: 1,
      metalness: 0,
      side: THREE.DoubleSide,
    }),
  );
  shatteredGround.rotation.x = -Math.PI / 2;
  shatteredGround.position.y = 0.05;
  craterRoot.add(shatteredGround);

  for (let index = 0; index < 48; index += 1) {
    const angle = (Math.PI * 2 * index) / 48;
    const radius = (14 + Math.random() * 12) * craterScale;
    const slab = new THREE.Mesh(
      new THREE.BoxGeometry(
        (1.6 + Math.random() * 4.8) * craterScale,
        (0.55 + Math.random() * 1.8) * craterScale,
        (1.6 + Math.random() * 4.8) * craterScale,
      ),
      new THREE.MeshStandardMaterial({
        color: index % 2 === 0 ? 0x5d4c3c : 0x3c332e,
        roughness: 1,
        metalness: 0.02,
      }),
    );
    slab.position.set(
      Math.cos(angle) * radius,
      (0.22 + Math.random() * 0.45) * craterScale,
      Math.sin(angle) * radius,
    );
    slab.rotation.set(Math.random() * 0.45, Math.random() * Math.PI, Math.random() * 0.45);
    slab.castShadow = true;
    slab.receiveShadow = true;
    craterRoot.add(slab);
  }
}

function damageStructures(epicenter, explosionMultiplier = 1) {
  const structureDamageRadius = 230 * explosionMultiplier;
  for (const structure of destructibleStructures) {
    if (structure.destroyed) {
      continue;
    }
    if (structure.megacitySection && !structure.megacitySection.destroyed) {
      continue;
    }

    const distance = structure.position.distanceTo(epicenter);
    if (distance > structureDamageRadius) {
      continue;
    }

    const blastStrength = THREE.MathUtils.clamp(1 - distance / structureDamageRadius, 0.18, 1);
    if (structure.isTower) {
      collapseTower(structure, epicenter, blastStrength);
    } else {
      shatterStructure(structure, epicenter, blastStrength);
    }
  }
}

function removeStructure(structure) {
  if (structure.megacitySection) {
    structure.destroyed = true;
    scene.remove(structure.building);
    if (structure.roof) {
      scene.remove(structure.roof);
    }
    if (structure.antenna) {
      scene.remove(structure.antenna);
    }
    return;
  }

  if (structure.town && !structure.town.destroyed) {
    structure.town.destroyed = true;
    score += structure.town.points;
    updateScoreDisplay();
  }

  structure.destroyed = true;
  scene.remove(structure.building);
  if (structure.roof) {
    scene.remove(structure.roof);
  }
  if (structure.antenna) {
    scene.remove(structure.antenna);
  }
}

function spawnStructureDebris(structure, epicenter, blastStrength, pieceCount, shardCount) {
  const origin = structure.position.clone();

  for (let index = 0; index < pieceCount; index += 1) {
    const piece = new THREE.Mesh(
      new THREE.BoxGeometry(
        0.8 + Math.random() * (structure.size.width * 0.28),
        0.8 + Math.random() * 3.8,
        0.8 + Math.random() * (structure.size.depth * 0.28),
      ),
      new THREE.MeshStandardMaterial({
        color: index % 2 === 0 ? structure.color : 0x484e57,
        roughness: 0.96,
        metalness: 0.05,
      }),
    );
    const basePosition = origin.clone().add(
      new THREE.Vector3(
        (Math.random() - 0.5) * structure.size.width * 0.8,
        Math.random() * structure.size.height,
        (Math.random() - 0.5) * structure.size.depth * 0.8,
      ),
    );
    piece.position.copy(basePosition);
    piece.castShadow = true;
    piece.receiveShadow = true;
    scene.add(piece);

    const blastDirection = basePosition.clone().sub(epicenter).setY(0);
    if (blastDirection.lengthSq() === 0) {
      blastDirection.set(Math.random() - 0.5, 0, Math.random() - 0.5);
    }
    blastDirection.normalize();

    activeCollapseChunks.push({
      mesh: piece,
      velocity: blastDirection.multiplyScalar(18 + Math.random() * 34 * blastStrength).setY(12 + Math.random() * 18 * blastStrength),
      spin: new THREE.Vector3(2 + Math.random() * 8, 2 + Math.random() * 8, 2 + Math.random() * 8),
    });
  }

  for (let index = 0; index < shardCount; index += 1) {
    const shard = new THREE.Mesh(
      new THREE.BoxGeometry(0.1 + Math.random() * 0.35, 0.1 + Math.random() * 0.25, 0.5 + Math.random() * 1.6),
      new THREE.MeshStandardMaterial({
        color: index % 2 === 0 ? 0x7f858c : 0x4f565f,
        roughness: 0.68,
        metalness: 0.44,
      }),
    );
    const angle = Math.random() * Math.PI * 2;
    const speed = 30 + Math.random() * 42 * blastStrength;
    shard.position.copy(origin).add(
      new THREE.Vector3(
        (Math.random() - 0.5) * structure.size.width * 0.35,
        4 + Math.random() * structure.size.height * 0.65,
        (Math.random() - 0.5) * structure.size.depth * 0.35,
      ),
    );
    shard.castShadow = true;
    scene.add(shard);

    activeCollapseChunks.push({
      mesh: shard,
      velocity: new THREE.Vector3(
        Math.cos(angle) * speed,
        10 + Math.random() * 22 * blastStrength,
        Math.sin(angle) * speed,
      ),
      spin: new THREE.Vector3(5 + Math.random() * 10, 5 + Math.random() * 10, 5 + Math.random() * 10),
    });
  }
}

function createStructureBurst(position, color, blastStrength) {
  const burstRoot = new THREE.Group();
  burstRoot.position.copy(position);
  scene.add(burstRoot);

  const core = new THREE.Mesh(
    new THREE.SphereGeometry(1.2 + blastStrength * 1.5, 20, 20),
    new THREE.MeshBasicMaterial({
      color: 0xffbb66,
      transparent: true,
      opacity: 0.95,
    }),
  );
  burstRoot.add(core);

  const halo = new THREE.Mesh(
    new THREE.SphereGeometry(1 + blastStrength * 1.2, 18, 18),
    new THREE.MeshBasicMaterial({
