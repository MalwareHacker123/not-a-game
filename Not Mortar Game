function clientToMapCanvasPx(clientX, clientY) {
  const rect = mapCanvasElement.getBoundingClientRect();
  const size = mapCanvasElement.width;
  if (rect.width < 1 || rect.height < 1) {
    return { x: size * 0.5, y: size * 0.5 };
  }
  return {
    x: THREE.MathUtils.clamp(((clientX - rect.left) / rect.width) * size, 0, size),
    y: THREE.MathUtils.clamp(((clientY - rect.top) / rect.height) * size, 0, size),
  };
}

/** Compass bearing from (x0,z0) to (x1,z1): 0° = +Z north, clockwise — matches map and HUD. */
function worldGridBearingDeg(x0, z0, x1, z1) {
  let deg = THREE.MathUtils.radToDeg(Math.atan2(x1 - x0, z1 - z0));
  if (deg < 0) {
    deg += 360;
  }
  return deg;
}

/** NATO-style mils (0–6399), 6400 mil = 360° — common on plotting boards / mortars. */
function compassDegToNatoMils(deg) {
  let m = Math.round(((deg % 360) + 360) % 360 * (6400 / 360));
  if (m >= 6400) {
    m -= 6400;
  }
  return m;
}

function formatCompassDegThreeDigits(deg) {
  const n = ((Math.round(deg) % 360) + 360) % 360;
  return String(n).padStart(3, "0");
}

function getMapPlotElapsedSeconds() {
  if (mapPlotTimerStartMs == null) {
    return null;
  }
  const endMs = mapPlotTimerEndMs != null ? mapPlotTimerEndMs : performance.now();
  return (endMs - mapPlotTimerStartMs) / 1000;
}

function getMapProtractorArmWorldFt() {
  return MAP_PROTRACTOR_FT_PER_TOOL_INCH * MAP_PROTRACTOR_LEG_INCHES;
}

function protractorRotateXZ(dx, dz, theta) {
  const c = Math.cos(theta);
  const s = Math.sin(theta);
  return { x: dx * c - dz * s, z: dx * s + dz * c };
}

function getProtractorGeometryWorld(pivotMx, pivotMz, legWorldFt, theta) {
  const h = legWorldFt / Math.SQRT2;
  const gx = h / 3;
  const gz = h / 3;
  const t = MAP_PROTRACTOR_FRAME_INSET;
  function insetLocal(lx, lz) {
    return { x: lx + (gx - lx) * t, z: lz + (gz - lz) * t };
  }
  const vR = protractorRotateXZ(0, h, theta);
  const bR = protractorRotateXZ(h, 0, theta);
  const outerM = { x: pivotMx, z: pivotMz };
  const outerV = { x: pivotMx + vR.x, z: pivotMz + vR.z };
  const outerB = { x: pivotMx + bR.x, z: pivotMz + bR.z };
  const im = insetLocal(0, 0);
  const iv = insetLocal(0, h);
  const ib = insetLocal(h, 0);
  const innerM = (() => {
    const r = protractorRotateXZ(im.x, im.z, theta);
    return { x: pivotMx + r.x, z: pivotMz + r.z };
  })();
  const innerV = (() => {
    const r = protractorRotateXZ(iv.x, iv.z, theta);
    return { x: pivotMx + r.x, z: pivotMz + r.z };
  })();
  const innerB = (() => {
    const r = protractorRotateXZ(ib.x, ib.z, theta);
    return { x: pivotMx + r.x, z: pivotMz + r.z };
  })();
  return { h, outerM, outerV, outerB, innerM, innerV, innerB };
}

function pointInTriXZ(px, pz, a, b, c) {
  const v0x = b.x - a.x;
  const v0z = b.z - a.z;
  const v1x = c.x - a.x;
  const v1z = c.z - a.z;
  const v2x = px - a.x;
  const v2z = pz - a.z;
  const d00 = v0x * v0x + v0z * v0z;
  const d01 = v0x * v1x + v0z * v1z;
  const d11 = v1x * v1x + v1z * v1z;
  const d20 = v2x * v0x + v2z * v0z;
  const d21 = v2x * v1x + v2z * v1z;
  const denom = d00 * d11 - d01 * d01;
  if (Math.abs(denom) < 1e-14) {
    return false;
  }
  const v = (d11 * d20 - d01 * d21) / denom;
  const w = (d00 * d21 - d01 * d20) / denom;
  const u = 1 - v - w;
  return u >= -1e-6 && v >= -1e-6 && w >= -1e-6;
}

function pointInProtractorFrameWorld(geo, wx, wz) {
  const { outerM, outerV, outerB, innerM, innerV, innerB } = geo;
  if (!pointInTriXZ(wx, wz, outerM, outerV, outerB)) {
    return false;
  }
  if (pointInTriXZ(wx, wz, innerM, innerV, innerB)) {
    return false;
  }
  return true;
}

function mapPointHitsPlacedProtractorWorld(wx, wz) {
  if (!mapMeasureLineEnd || !mapProtractorCenterWorld || mapProtractorMoveActive) {
    return false;
  }
  const legFt = getMapProtractorArmWorldFt() * MAP_PROTRACTOR_HIT_LEG_SCALE;
  const geo = getProtractorGeometryWorld(
    mapProtractorCenterWorld.x,
    mapProtractorCenterWorld.z,
    legFt,
    mapProtractorRotationRad,
  );
  return pointInTriXZ(wx, wz, geo.outerM, geo.outerV, geo.outerB);
}

function mapProtractorScreenHit(clientX, clientY) {
  const w = mapToWorld(clientX, clientY);
  return mapPointHitsPlacedProtractorWorld(w.x, w.z);
}

function getProtractorPivotWorldForDraw() {
  if (!mapMeasureLineEnd || hasTrackingShellReady()) {
    return null;
  }
  if (mapProtractorMoveActive) {
    if (mapProtractorHoverClient) {
      return mapToWorld(mapProtractorHoverClient.clientX, mapProtractorHoverClient.clientY);
    }
    const rect = mapCanvasElement.getBoundingClientRect();
    return mapToWorld(rect.left + rect.width * 0.5, rect.top + rect.height * 0.5);
  }
  return mapProtractorCenterWorld;
}

function shouldDrawSimpleProtractor() {
  return Boolean(mapMeasureLineEnd && (mapProtractorMoveActive || mapProtractorCenterWorld));
}

function canvasNormalToward(p0, p1, towardX, towardY) {
  const dx = p1.x - p0.x;
  const dy = p1.y - p0.y;
  const len = Math.hypot(dx, dy) || 1;
  let nx = -dy / len;
  let ny = dx / len;
  const mx = (p0.x + p1.x) * 0.5;
  const my = (p0.y + p1.y) * 0.5;
  if (nx * (towardX - mx) + ny * (towardY - my) < 0) {
    nx = -nx;
    ny = -ny;
  }
  return { nx, ny };
}

function drawCanvasProtractorRuler(ctx, p0, p1, nx, ny, strokeAlpha, outer, labelMax) {
  const steps = outer ? 14 : 28;
  const dx = p1.x - p0.x;
  const dy = p1.y - p0.y;
  const sl = Math.hypot(dx, dy) || 1;
  const ux = dx / sl;
  const uy = dy / sl;
  const fontPx = outer ? 12 : 8;
  const a = Math.min(1, strokeAlpha);
  for (let i = 0; i <= steps; i += 1) {
    const t = i / steps;
    const px = p0.x + ux * sl * t;
    const py = p0.y + uy * sl * t;
    const majorOuter = outer && i % 7 === 0;
    const majorInner = !outer && i % 7 === 0;
    const half = !majorOuter && !majorInner && i % 2 === 0;
    const tl = majorOuter ? 13 : majorInner ? 8 : half ? (outer ? 7.5 : 5.5) : outer ? 5 : 3.5;
    ctx.beginPath();
    ctx.moveTo(px, py);
    ctx.lineTo(px + nx * tl, py + ny * tl);
    ctx.strokeStyle =
      majorOuter || majorInner
        ? `rgba(255, 252, 238, ${0.98 * a})`
        : `rgba(220, 228, 240, ${0.88 * a})`;
    ctx.lineWidth = majorOuter || majorInner ? 2.4 : half ? 1.45 : 1;
    ctx.stroke();
    if (majorOuter) {
      const val = Math.round((labelMax * i) / steps);
      const lx = px + nx * (tl + 11);
      const ly = py + ny * (tl + 11);
      ctx.font = `800 ${fontPx}px ui-monospace, monospace`;
      ctx.textAlign = "center";
      ctx.textBaseline = "middle";
      ctx.lineWidth = 3;
      ctx.strokeStyle = `rgba(0,0,0,${0.75 * a})`;
      ctx.fillStyle = `rgba(255, 250, 235, ${0.99 * a})`;
      ctx.strokeText(String(val), lx, ly);
      ctx.fillText(String(val), lx, ly);
    }
    if (majorInner) {
      const val = Math.round((labelMax * i) / steps);
      const lx = px + nx * (tl + 8);
      const ly = py + ny * (tl + 8);
      ctx.font = `700 ${fontPx}px ui-monospace, monospace`;
      ctx.textAlign = "center";
      ctx.textBaseline = "middle";
      ctx.lineWidth = 2.2;
      ctx.strokeStyle = `rgba(0,0,0,${0.65 * a})`;
      ctx.fillStyle = `rgba(235, 240, 252, ${0.96 * a})`;
      ctx.strokeText(String(val), lx, ly);
      ctx.fillText(String(val), lx, ly);
    }
  }
}

function drawNavigationTriangleProtractor(ctx, pivotWx, pivotWz, legWorldFt, theta, strokeAlpha) {
  const geo = getProtractorGeometryWorld(pivotWx, pivotWz, legWorldFt, theta);
  const pM = worldToMap(geo.outerM.x, geo.outerM.z);
  const pV = worldToMap(geo.outerV.x, geo.outerV.z);
  const pB = worldToMap(geo.outerB.x, geo.outerB.z);
  const pMi = worldToMap(geo.innerM.x, geo.innerM.z);
  const pVi = worldToMap(geo.innerV.x, geo.innerV.z);
  const pBi = worldToMap(geo.innerB.x, geo.innerB.z);

  const legPx = Math.hypot(pV.x - pM.x, pV.y - pM.y);
  const mbLen = Math.hypot(pB.x - pM.x, pB.y - pM.y) || 1;
  const baseLw = Math.max(2.2, Math.min(4.2, legPx * 0.014));
  const idxLw = Math.max(2.8, Math.min(5, legPx * 0.018));

  const cex = (pM.x + pV.x + pB.x) / 3;
  const cey = (pM.y + pV.y + pB.y) / 3;

  const nMBoutRaw = canvasNormalToward(pM, pB, pV.x, pV.y);
  const nMBout = { nx: -nMBoutRaw.nx, ny: -nMBoutRaw.ny };
  const nMBin = canvasNormalToward(pMi, pBi, cex, cey);

  const nMVoutRaw = canvasNormalToward(pM, pV, pB.x, pB.y);
  const nMVout = { nx: -nMVoutRaw.nx, ny: -nMVoutRaw.ny };
  const nMVin = canvasNormalToward(pMi, pVi, cex, cey);

  ctx.save();
  ctx.lineCap = "round";
  ctx.lineJoin = "round";

  ctx.beginPath();
  ctx.moveTo(pM.x, pM.y);
  ctx.lineTo(pB.x, pB.y);
  ctx.lineTo(pV.x, pV.y);
  ctx.closePath();
  ctx.moveTo(pMi.x, pMi.y);
  ctx.lineTo(pVi.x, pVi.y);
  ctx.lineTo(pBi.x, pBi.y);
  ctx.closePath();
  ctx.fillStyle = `rgba(248, 252, 255, ${0.22 + strokeAlpha * 0.18})`;
  ctx.fill("evenodd");

  ctx.beginPath();
  ctx.moveTo(pM.x, pM.y);
  ctx.lineTo(pB.x, pB.y);
  ctx.lineTo(pV.x, pV.y);
  ctx.closePath();
  ctx.strokeStyle = `rgba(255, 252, 245, ${0.95 * strokeAlpha})`;
  ctx.lineWidth = baseLw;
  ctx.stroke();
  ctx.strokeStyle = `rgba(8, 10, 18, ${0.5 * strokeAlpha})`;
  ctx.lineWidth = Math.max(1, baseLw * 0.35);
  ctx.stroke();

  ctx.beginPath();
  ctx.moveTo(pMi.x, pMi.y);
  ctx.lineTo(pVi.x, pVi.y);
  ctx.lineTo(pBi.x, pBi.y);
  ctx.closePath();
  ctx.strokeStyle = `rgba(230, 238, 250, ${0.9 * strokeAlpha})`;
  ctx.lineWidth = Math.max(1.4, baseLw * 0.85);
  ctx.stroke();

  ctx.beginPath();
  ctx.moveTo(pM.x, pM.y);
  ctx.lineTo(pV.x, pV.y);
  ctx.strokeStyle = `rgba(255, 245, 220, ${0.98 * strokeAlpha})`;
  ctx.lineWidth = idxLw;
  ctx.stroke();
  ctx.strokeStyle = `rgba(6, 8, 14, ${0.45 * strokeAlpha})`;
  ctx.lineWidth = Math.max(1, idxLw * 0.35);
  ctx.stroke();

  const vbMidx = (pV.x + pB.x) * 0.5;
  const vbMidy = (pV.y + pB.y) * 0.5;
  const vdx = pB.x - pV.x;
  const vdy = pB.y - pV.y;
  const vbl = Math.hypot(vdx, vdy) || 1;
  let pnx = -vdy / vbl;
  let pny = vdx / vbl;
  if (pnx * (cex - vbMidx) + pny * (cey - vbMidy) < 0) {
    pnx = -pnx;
    pny = -pny;
  }
  const clen = vbl * 0.42;
  ctx.beginPath();
  ctx.moveTo(vbMidx - pnx * clen * 0.5, vbMidy - pny * clen * 0.5);
  ctx.lineTo(vbMidx + pnx * clen * 0.5, vbMidy + pny * clen * 0.5);
  ctx.strokeStyle = `rgba(255, 248, 230, ${0.96 * strokeAlpha})`;
  ctx.lineWidth = Math.max(2, baseLw * 0.72);
  ctx.stroke();
  ctx.strokeStyle = `rgba(10, 12, 20, ${0.45 * strokeAlpha})`;
  ctx.lineWidth = Math.max(1, baseLw * 0.32);
  ctx.stroke();

  drawCanvasProtractorRuler(ctx, pM, pB, nMBout.nx, nMBout.ny, strokeAlpha, true, 7);
  drawCanvasProtractorRuler(ctx, pMi, pBi, nMBin.nx, nMBin.ny, strokeAlpha, false, 7);
  drawCanvasProtractorRuler(ctx, pM, pV, nMVout.nx, nMVout.ny, strokeAlpha, true, 7);
  drawCanvasProtractorRuler(ctx, pMi, pVi, nMVin.nx, nMVin.ny, strokeAlpha, false, 7);

  function labelAngle(px, py, ox, oy, text) {
    ctx.font = "800 11px ui-monospace, monospace";
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.lineWidth = 3;
    ctx.strokeStyle = `rgba(0,0,0,${0.55 * strokeAlpha})`;
    ctx.fillStyle = `rgba(255, 252, 245, ${0.98 * strokeAlpha})`;
    ctx.strokeText(text, px + ox, py + oy);
    ctx.fillText(text, px + ox, py + oy);
  }
  const mbx = (pB.x - pM.x) / mbLen;
  const mby = (pB.y - pM.y) / mbLen;
  const uvx = (pV.x - pM.x) / legPx;
  const uvy = (pV.y - pM.y) / legPx;
  const bsx = uvx + mbx;
  const bsy = uvy + mby;
  const blen = Math.hypot(bsx, bsy) || 1;
  labelAngle(pM.x, pM.y, (bsx / blen) * 17, (bsy / blen) * 17, "90°");
  const wvx = (pM.x - pV.x) / legPx;
  const wvy = (pM.y - pV.y) / legPx;
  const vbLenU = Math.hypot(pB.x - pV.x, pB.y - pV.y) || 1;
  const wbx = (pB.x - pV.x) / vbLenU;
  const wby = (pB.y - pV.y) / vbLenU;
  const vsx = wvx + wbx;
  const vsy = wvy + wby;
  const vlen = Math.hypot(vsx, vsy) || 1;
  labelAngle(pV.x, pV.y, (vsx / vlen) * 14, (vsy / vlen) * 14, "45°");
  const umx = (pM.x - pB.x) / mbLen;
  const umy = (pM.y - pB.y) / mbLen;
  const bvLenU = Math.hypot(pV.x - pB.x, pV.y - pB.y) || 1;
  const uvbx = (pV.x - pB.x) / bvLenU;
  const uvby = (pV.y - pB.y) / bvLenU;
  const bsbx = umx + uvbx;
  const bsby = umy + uvby;
  const bslen = Math.hypot(bsbx, bsby) || 1;
  labelAngle(pB.x, pB.y, (bsbx / bslen) * 13, (bsby / bslen) * 13, "45°");

  ctx.restore();
}

function drawMapSimpleProtractor(ctx) {
  if (!shouldDrawSimpleProtractor()) {
    return;
  }
  const pivot = getProtractorPivotWorldForDraw();
  if (!pivot) {
    return;
  }
  const strokeAlpha = mapProtractorMoveActive ? 0.88 : 1;
  drawNavigationTriangleProtractor(
    ctx,
    pivot.x,
    pivot.z,
    getMapProtractorArmWorldFt(),
    mapProtractorRotationRad,
    strokeAlpha,
  );
}

/** Live chord range, grid bearing, NATO mils, and plot stopwatch — mortar plotting-board style. */
function drawMapPlottingMathHud(ctx) {
  if (!mapMeasureLineEnd || hasTrackingShellReady() || trackedProjectile || carpetBombMode) {
    return;
  }

  const mx = MORTAR_POSITION.x;
  const mz = MORTAR_POSITION.z;
  const ex = mapMeasureLineEnd.x;
  const ez = mapMeasureLineEnd.z;
  const chordFt = Math.hypot(ex - mx, ez - mz);
  const brgGun = worldGridBearingDeg(mx, mz, ex, ez);
  const milGun = compassDegToNatoMils(brgGun);
  const elapsed = getMapPlotElapsedSeconds();

  const lines = [
    "Plot board — math",
    `Mortar → aim: ${Math.round(chordFt)} ft chord`,
    `True brg: ${formatCompassDegThreeDigits(brgGun)}°   ${milGun} mil`,
  ];
  if (mapProtractorMoveActive) {
    lines.push("Q mode — triangle follows pointer (pivot = hypotenuse midpoint); click to confirm");
  } else if (!mapProtractorCenterWorld) {
    lines.push(
      `Press Q: half 45°-45°-90° tool (${MAP_PROTRACTOR_LEG_INCHES}″ legs @ ${MAP_PROTRACTOR_FT_PER_TOOL_INCH.toLocaleString()} ft/in)`,
    );
  } else {
    lines.push("Placed — map drag ↔ rotate · drag on tool to move · Q→click re-aim · Q→click place");
  }
  if (elapsed != null) {
    lines.push(
      mapPlotTimerEndMs != null
        ? `Plot time: ${elapsed.toFixed(2)} s (locked)`
        : `Plot time: ${elapsed.toFixed(2)} s …`,
    );
  }

  ctx.save();
  const lineH = 14;
  const pad = 10;
  const w = 340;
  const h = pad * 2 + lines.length * lineH;
  const x0 = 10;
  const y0 = 10;
  ctx.fillStyle = "rgba(14, 20, 30, 0.9)";
  ctx.strokeStyle = "rgba(255, 255, 255, 0.12)";
  ctx.lineWidth = 1;
  if (typeof ctx.roundRect === "function") {
    ctx.beginPath();
    ctx.roundRect(x0, y0, w, h, 8);
    ctx.fill();
    ctx.stroke();
  } else {
    ctx.fillRect(x0, y0, w, h);
    ctx.strokeRect(x0, y0, w, h);
  }
  ctx.fillStyle = "rgba(230, 238, 248, 0.94)";
  ctx.font = "600 11px ui-monospace, monospace";
  ctx.textAlign = "left";
  ctx.textBaseline = "top";
  for (let i = 0; i < lines.length; i += 1) {
    ctx.fillText(lines[i], x0 + pad, y0 + pad + i * lineH);
  }
  ctx.restore();
}

/** Bearing 0° = world +Z (toward top of map grid), increasing clockwise — matches lubber line readout. */
function getPlayerHeadingDegrees() {
  const fwd = new THREE.Vector3(0, 0, -1).applyAxisAngle(new THREE.Vector3(0, 1, 0), pointer.yaw);
  let deg = THREE.MathUtils.radToDeg(Math.atan2(fwd.x, fwd.z));
  if (deg < 0) {
    deg += 360;
  }
  return deg;
}

function syncCompassHud() {
  if (!compassHudElement || !compassDialElement || !compassDegreesElement) {
    return;
  }
  if (!gameStarted || !compassMapOn || mapOpen || trackedProjectile || cinematicImpactTimer > 0) {
    compassHudElement.hidden = true;
    compassHudElement.setAttribute("aria-hidden", "true");
    return;
  }
  compassHudElement.hidden = false;
  compassHudElement.setAttribute("aria-hidden", "false");
  const h = getPlayerHeadingDegrees();
  compassDialElement.style.transform = `rotate(${-h}deg)`;
  compassDegreesElement.textContent = `${String(Math.round(h)).padStart(3, "0")}°`;

  if (compassTubeBrgElement) {
    const showTube =
      mortarRoot && mortarTube && ((mortarRotateMode && isNearMortar()) || isLookingAtMortar());
    if (showTube) {
      const brg = getMortarTubeAzimuthDegrees();
      compassTubeBrgElement.hidden = false;
      compassTubeBrgElement.textContent = `Tube ${String(Math.round(brg)).padStart(3, "0")}° (map N)`;
    } else {
      compassTubeBrgElement.hidden = true;
    }
  }
}

/** Map is north-up: rose fixed to true north with 0–360° scale (does not spin with view). */
function drawMapCompassRose(ctx, size) {
  const r = 66;
  const margin = 18;
  const cx = size - margin - r;
  const cy = margin + r;

  ctx.save();
  ctx.translate(cx, cy);

  ctx.fillStyle = "rgba(10, 16, 28, 0.96)";
  ctx.beginPath();
  ctx.arc(0, 0, r, 0, Math.PI * 2);
  ctx.fill();
  ctx.strokeStyle = "rgba(255,255,255,0.45)";
  ctx.lineWidth = 2.5;
  ctx.stroke();

  for (let deg = 0; deg < 360; deg += 1) {
    const rad = -Math.PI / 2 + THREE.MathUtils.degToRad(deg);
    const c0 = Math.cos(rad);
    const s0 = Math.sin(rad);
    const card = deg % 90 === 0;
    const ten = deg % 10 === 0;
    const five = deg % 5 === 0;
    const tlen = card ? 16 : ten ? 11 : five ? 7 : 4;
    ctx.beginPath();
    ctx.moveTo(c0 * (r - tlen), s0 * (r - tlen));
    ctx.lineTo(c0 * r, s0 * r);
    ctx.strokeStyle = card
      ? "rgba(255, 255, 255, 0.92)"
      : ten
        ? "rgba(230, 236, 248, 0.78)"
        : five
          ? "rgba(200, 210, 228, 0.55)"
          : "rgba(160, 176, 200, 0.38)";
    ctx.lineWidth = card ? 2 : ten ? 1.35 : five ? 1 : 0.65;
    ctx.stroke();
  }

  const labelR = r - 24;
  for (let deg = 0; deg < 360; deg += 10) {
    if (deg % 90 === 0) {
      continue;
    }
    const rad = -Math.PI / 2 + THREE.MathUtils.degToRad(deg);
    const lx = Math.cos(rad) * labelR;
    const ly = Math.sin(rad) * labelR;
    ctx.font = "700 8px ui-monospace, monospace";
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.lineWidth = 2.5;
    ctx.strokeStyle = "rgba(0,0,0,0.55)";
    ctx.strokeText(String(deg), lx, ly);
    ctx.fillStyle = "rgba(248, 250, 255, 0.95)";
    ctx.fillText(String(deg), lx, ly);
  }

  ctx.textAlign = "center";
  ctx.textBaseline = "middle";
  ctx.lineWidth = 3;
  function cardLabel(txt, deg, fontPx) {
    const rad = -Math.PI / 2 + THREE.MathUtils.degToRad(deg);
    const lx = Math.cos(rad) * (r - 20);
    const ly = Math.sin(rad) * (r - 20);
    ctx.font = `bold ${fontPx}px system-ui, sans-serif`;
    ctx.strokeStyle = "rgba(0,0,0,0.5)";
    ctx.strokeText(txt, lx, ly);
    ctx.fillStyle = deg === 0 ? "#fecaca" : "#e8ecf4";
    ctx.fillText(txt, lx, ly);
  }
  cardLabel("N", 0, 13);
  cardLabel("E", 90, 12);
  cardLabel("S", 180, 12);
  cardLabel("W", 270, 12);
  ctx.font = "700 7px ui-monospace, monospace";
  ctx.fillStyle = "rgba(255, 220, 220, 0.95)";
  ctx.strokeStyle = "rgba(0,0,0,0.45)";
  ctx.lineWidth = 2;
  ctx.strokeText("0", 0, -(r - 30));
  ctx.fillText("0", 0, -(r - 30));

  ctx.font = "600 9px system-ui, sans-serif";
  ctx.fillStyle = "rgba(232, 236, 244, 0.8)";
  const ri = r - 36;
  const q = ri * 0.7071;
  ctx.fillText("NE", q, -q);
  ctx.fillText("SE", q, q);
  ctx.fillText("SW", -q, q);
  ctx.fillText("NW", -q, -q);

  ctx.beginPath();
  ctx.moveTo(0, -(r + 3));
  ctx.lineTo(-9, -(r - 11));
  ctx.lineTo(9, -(r - 11));
  ctx.closePath();
  ctx.fillStyle = "rgba(249, 115, 22, 0.98)";
  ctx.fill();
  ctx.strokeStyle = "rgba(40, 20, 8, 0.55)";
  ctx.lineWidth = 1;
  ctx.stroke();

  ctx.restore();

  ctx.fillStyle = "rgba(244, 247, 251, 0.9)";
  ctx.font = "600 9px system-ui, sans-serif";
  ctx.textAlign = "center";
  ctx.textBaseline = "top";
  ctx.fillText("North-up · map grid 0° = N · C = HUD compass when playing", cx, cy + r + 6);
}

function drawMapGridWorldFt(ctx, size) {
  const step = MAP_GRID_FT;
  const H = getMapHalfExtentFt();
  const c = getMapCenterXZ();
  const x0 = Math.floor((c.x - H) / step) * step;
  const x1 = Math.ceil((c.x + H) / step) * step;
  const z0 = Math.floor((c.z - H) / step) * step;
  const z1 = Math.ceil((c.z + H) / step) * step;

  ctx.strokeStyle = "rgba(255,255,255,0.07)";
  ctx.lineWidth = 1;
  for (let w = x0; w <= x1; w += step) {
    const p = worldToMap(w, c.z);
    if (p.x < -1 || p.x > size + 1) {
      continue;
    }
    ctx.beginPath();
    ctx.moveTo(p.x, 0);
    ctx.lineTo(p.x, size);
    ctx.stroke();
  }
  for (let w = z0; w <= z1; w += step) {
    const p = worldToMap(c.x, w);
    if (p.y < -1 || p.y > size + 1) {
      continue;
    }
    ctx.beginPath();
    ctx.moveTo(0, p.y);
    ctx.lineTo(size, p.y);
    ctx.stroke();
  }
}

function renderMap() {
  const ctx = mapContext;
  const size = mapCanvasElement.width;
  ctx.clearRect(0, 0, size, size);

  const gradient = ctx.createLinearGradient(0, 0, 0, size);
  gradient.addColorStop(0, "#16202e");
  gradient.addColorStop(1, "#101720");
  ctx.fillStyle = gradient;
  ctx.fillRect(0, 0, size, size);

  syncMapScaleKey();

  if (trackedProjectile) {
    mapInstructionsElement.innerHTML =
      "<strong>Shell in flight</strong> — map is locked during this view. Press <strong>Z</strong> to exit shell camera, then use the map again.";
  } else if (carpetBombMode) {
    mapInstructionsElement.innerHTML = `1) <strong>Click</strong> pivot (green ○). 2) Move mouse — line aims from that point; dashed = <strong>${CARPET_BOMB_MAX_FT.toLocaleString()} ft</strong> max. 3) <strong>Spin</strong> with <strong>Q / E</strong>, <strong>← / →</strong>, <strong>, / .</strong>, or <strong>mouse wheel</strong>. 4) <strong>Click</strong> again to confirm. <strong>${CARPET_MICRO_BOMB_COUNT}</strong> bombs. <strong>M</strong> / <strong>Esc</strong> cancel.`;
  } else {
    mapInstructionsElement.innerHTML =
      `Press <strong>M</strong> or <strong>Esc</strong> to close. <strong>North-up</strong> on mortar. Corner rose = true north (<strong>0–360°</strong>); <strong>C</strong> = HUD compass when playing. <strong>HE / HS</strong>: click <strong>aim line</strong>, <strong>Q</strong> — <strong>half 45° set square</strong> (pivot at hypotenuse midpoint); click to place. Placed: drag on map <strong>left↔right</strong> to rotate; drag <strong>on tool</strong> to move; <strong>Q</strong>→click re-aim (clears), <strong>Q</strong>→click place. Map ≈ <strong>${Math.round(getMapFeetPerScreenInch())} ft</strong> per screen inch. <strong>Double-click</strong> clears. <strong>Tracking</strong>: click target.`;
  }

  drawMapGridWorldFt(ctx, size);

  const mortarPoint = worldToMap(MORTAR_POSITION.x, MORTAR_POSITION.z);
  ctx.fillStyle = "#9be7ff";
  ctx.beginPath();
  ctx.arc(mortarPoint.x, mortarPoint.y, 7, 0, Math.PI * 2);
  ctx.fill();

  ctx.fillStyle = "#f4f7fb";
  ctx.font = "14px sans-serif";
  ctx.fillText("Mortar", mortarPoint.x + 10, mortarPoint.y - 10);

  for (const town of targetTowns) {
    const townPoint = worldToMap(town.center.x, town.center.z);
    if (town.isMegacity) {
      ctx.fillStyle = town.destroyed ? "#6a7582" : "#e8c66a";
      ctx.beginPath();
      ctx.arc(townPoint.x, townPoint.y, 11, 0, Math.PI * 2);
      ctx.fill();
      ctx.strokeStyle = "rgba(255,255,255,0.25)";
      ctx.lineWidth = 2;
      ctx.stroke();
      ctx.fillStyle = town.destroyed ? "rgba(244,247,251,0.5)" : "#f4f7fb";
      ctx.font = "13px sans-serif";
      ctx.fillText(town.name, townPoint.x + 14, townPoint.y - 8);
      ctx.font = "10px sans-serif";
      for (const sec of town.sections) {
        const sp = worldToMap(sec.center.x, sec.center.z);
        const hpRatio = sec.destroyed ? 0 : sec.hp / sec.maxHp;
        ctx.fillStyle = sec.destroyed ? "#5a6570" : hpRatio > 0.55 ? "#6cb86a" : hpRatio > 0.22 ? "#c9a227" : "#c45c3a";
        ctx.beginPath();
        ctx.arc(sp.x, sp.y, 5, 0, Math.PI * 2);
        ctx.fill();
        ctx.strokeStyle = "rgba(0,0,0,0.35)";
        ctx.lineWidth = 1;
        ctx.stroke();
        ctx.fillStyle = sec.destroyed ? "rgba(244,247,251,0.35)" : "rgba(244,247,251,0.85)";
        ctx.fillText(sec.name, sp.x + 8, sp.y + 3);
      }
      ctx.font = "14px sans-serif";
      continue;
    }

    ctx.font = "14px sans-serif";
    ctx.fillStyle = town.destroyed ? "#7d8a98" : "#ffd77c";
    ctx.beginPath();
    ctx.arc(townPoint.x, townPoint.y, 9, 0, Math.PI * 2);
    ctx.fill();

    ctx.fillStyle = town.destroyed ? "rgba(244,247,251,0.45)" : "#f4f7fb";
    ctx.fillText(town.name, townPoint.x + 12, townPoint.y + 5);
  }

  drawMapShockwaveRipples(ctx, size);

  if (mapMeasureLineEnd && !hasTrackingShellReady() && !trackedProjectile) {
    const ep = worldToMap(mapMeasureLineEnd.x, mapMeasureLineEnd.z);
    ctx.strokeStyle = "rgba(255, 165, 88, 0.98)";
    ctx.lineWidth = 3;
    ctx.setLineDash([]);
    ctx.beginPath();
    ctx.moveTo(mortarPoint.x, mortarPoint.y);
    ctx.lineTo(ep.x, ep.y);
    ctx.stroke();
    ctx.fillStyle = "rgba(255, 210, 130, 0.98)";
    ctx.beginPath();
    ctx.arc(ep.x, ep.y, 7, 0, Math.PI * 2);
    ctx.fill();
    ctx.strokeStyle = "rgba(40, 28, 18, 0.55)";
    ctx.lineWidth = 1;
    ctx.stroke();

  }

  drawMapSimpleProtractor(ctx);
  drawMapPlottingMathHud(ctx);

  if (mapOpen && !trackedProjectile) {
    drawMapCompassRose(ctx, size);
  }

  drawMapCardinalEdgeLabels(ctx, size);

  if (trackedProjectile) {
    mapFooterElement.textContent = "View-only — no targeting — press M or Esc to close";
    return;
  }

  if (carpetBombMode) {
    const cdSec = getCarpetBombCooldownRemainingSec();
    const cdPrefix = cdSec > 0 ? `Recharging ${formatCarpetCooldownClock(cdSec)} — ` : "";
    const pp = new THREE.Vector3();
    player.getWorldPosition(pp);
    const playerPt = worldToMap(pp.x, pp.z);
    ctx.fillStyle = "rgba(120, 210, 255, 0.85)";
    ctx.beginPath();
    ctx.arc(playerPt.x, playerPt.y, 5, 0, Math.PI * 2);
    ctx.fill();

    if (!carpetBombLineStart) {
      carpetBombLastPreviewStrike = null;
      mapFooterElement.textContent = `${cdPrefix}Click where the carpet run STARTS (max ${CARPET_BOMB_MAX_FT.toLocaleString()} ft along your aim)`;
      return;
    }

    const sx = carpetBombLineStart.x;
    const sz = carpetBombLineStart.z;
    const pStart = worldToMap(sx, sz);
    ctx.fillStyle = "#4ade80";
    ctx.beginPath();
    ctx.arc(pStart.x, pStart.y, 10, 0, Math.PI * 2);
    ctx.fill();
    ctx.strokeStyle = "rgba(255,255,255,0.9)";
    ctx.lineWidth = 2;
    ctx.stroke();

    let tx = sx;
    let tz = sz;
    if (carpetBombMousePos) {
      const hoverWorld = mapToWorld(carpetBombMousePos.clientX, carpetBombMousePos.clientY);
      tx = hoverWorld.x;
      tz = hoverWorld.z;
    } else {
      tx = sx + Math.sin(pointer.yaw) * 420;
      tz = sz - Math.cos(pointer.yaw) * 420;
    }
    const strike = carpetBombStrikeFromAim(sx, sz, tx, tz, carpetBombHeadingAdjust);
    carpetBombLastPreviewStrike = strike;
    const maxEx = sx + strike.ux * CARPET_BOMB_MAX_FT;
    const maxEz = sz + strike.uz * CARPET_BOMB_MAX_FT;
    const pMax = worldToMap(maxEx, maxEz);

    ctx.strokeStyle = "rgba(255, 170, 90, 0.88)";
    ctx.lineWidth = 3;
    ctx.setLineDash([14, 8]);
    ctx.beginPath();
    ctx.moveTo(pStart.x, pStart.y);
    ctx.lineTo(pMax.x, pMax.y);
    ctx.stroke();
    ctx.setLineDash([]);

    ctx.fillStyle = "#f59e0b";
    ctx.beginPath();
    ctx.arc(pMax.x, pMax.y, 8, 0, Math.PI * 2);
    ctx.fill();
    ctx.strokeStyle = "rgba(255,255,255,0.9)";
    ctx.lineWidth = 2;
    ctx.stroke();

    ctx.fillStyle = "rgba(244, 247, 251, 0.95)";
    ctx.font = "600 11px system-ui, sans-serif";
    ctx.textAlign = "center";
    ctx.textBaseline = "bottom";
    ctx.fillText("max", pMax.x, pMax.y - 11);

    const segLen = strike.segmentLen;
    const capped = strike.aimChordLen > CARPET_BOMB_MAX_FT;
    const rotDeg = Math.round((carpetBombHeadingAdjust * 180) / Math.PI);
    mapFooterElement.textContent = `${cdPrefix}Line pivots on green ○ — aim with mouse, spin ${rotDeg >= 0 ? "+" : ""}${rotDeg}° (Q/E · ←/→ · , . · wheel) — strike ${Math.round(
      segLen,
    )} ft / ${CARPET_BOMB_MAX_FT.toLocaleString()} max${capped ? " (capped)" : ""} — click map to confirm`;
    ctx.textAlign = "start";
    ctx.textBaseline = "alphabetic";
    return;
  }

  const isTracking = hasTrackingShellReady();
  if (isTracking && trackingTarget) {
    const targetPoint = worldToMap(trackingTarget.x, trackingTarget.z);
    ctx.strokeStyle = "#ff6d6d";
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.moveTo(targetPoint.x - 12, targetPoint.y);
    ctx.lineTo(targetPoint.x + 12, targetPoint.y);
    ctx.moveTo(targetPoint.x, targetPoint.y - 12);
    ctx.lineTo(targetPoint.x, targetPoint.y + 12);
    ctx.stroke();
    mapFooterElement.textContent = "Tracking target set — click map to change";
  } else if (isTracking) {
    mapFooterElement.textContent = "Click on map to set tracking target";
  } else {
    const trajectoryData = getMortarTrajectoryData();
    if (trajectoryData && !trajectoryData.needsMapTarget && trajectoryData.points.length > 0) {
      const lineHint = mapProtractorMoveActive
        ? " | Q mode — click places tool, or re-aim+clear tool if you unlocked from placed; Q again cancels"
          : mapProtractorCenterWorld
          ? " | Map drag ↔ rotate · drag on tool to move · Q→click re-aim (clears tool)"
          : mapMeasureLineEnd
            ? " | Press Q: half set square follows pointer"
            : " | Left-click: mortar aim line first";
      let timeHint = "";
      const plotSec = getMapPlotElapsedSeconds();
      if (mapPlotTimerEndMs != null && plotSec != null) {
        timeHint = ` | plot time ${plotSec.toFixed(2)}s (locked)`;
      } else if (mapMeasureLineEnd && mapPlotTimerStartMs != null) {
        timeHint = " | stopwatch running — see plot board";
      }
      mapFooterElement.textContent = `${trajectoryData.shellDefinition.shortName}: HUD range ${Math.round(trajectoryData.range)} ft | brg ${String(Math.round(trajectoryData.azimuthDeg)).padStart(3, "0")}° | pitch ${Math.round(trajectoryData.angleDeg)}°${lineHint}${timeHint}`;
    } else {
      mapFooterElement.textContent =
        "Close map — R + WASD aim. HE/HS: aim line, Q for navigation triangle (follows pointer), click to place; double-click clears.";
    }
  }
}

function handleMapClick(event) {
  if (trackedProjectile || cinematicImpactTimer > 0) return;
  if (carpetBombMode) {
    const worldPoint = mapToWorld(event.clientX, event.clientY);
    const cdLeft = getCarpetBombCooldownRemainingSec();
    if (cdLeft > 0) {
      mapFooterElement.textContent = `Carpet bomb recharging — ${formatCarpetCooldownClock(cdLeft)} left`;
      renderMap();
      updateStatus();
      return;
    }
    if (!carpetBombLineStart) {
      carpetBombLineStart = { x: worldPoint.x, z: worldPoint.z };
      carpetBombHeadingAdjust = 0;
      mapCanvasElement.focus({ preventScroll: true });
      mapFooterElement.textContent =
        "Pivot set — move mouse to aim from it; Q/E ←/→ , . or wheel to spin line; click again to confirm";
      renderMap();
      return;
    }
    let runStart;
    let runEnd;
    let segmentLen;
    const preview = carpetBombLastPreviewStrike;
    if (preview && preview.segmentLen >= CARPET_BOMB_MIN_FT) {
      runStart = preview.start;
      runEnd = preview.end;
      segmentLen = preview.segmentLen;
    } else {
      const computed = carpetBombStrikeFromAim(
        carpetBombLineStart.x,
        carpetBombLineStart.z,
        worldPoint.x,
        worldPoint.z,
        carpetBombHeadingAdjust,
      );
      runStart = computed.start;
      runEnd = computed.end;
      segmentLen = computed.segmentLen;
    }
    if (segmentLen < CARPET_BOMB_MIN_FT) {
      mapFooterElement.textContent = `Aim farther from start (at least ${CARPET_BOMB_MIN_FT} ft) or pick a new start`;
      renderMap();
      return;
    }
    closeMap();
    startCarpetBombRun(runStart, runEnd);
    renderMap();
    return;
  }
  if (hasTrackingShellReady()) {
    const worldPoint = mapToWorld(event.clientX, event.clientY);
    trackingTarget = { x: worldPoint.x, z: worldPoint.z };
    renderMap();
    closeMap();
    return;
  }
  const worldPoint = mapToWorld(event.clientX, event.clientY);

  if (mapProtractorMoveActive) {
    if (mapProtractorSavedCenterWorld != null) {
      mapMeasureLineEnd = { x: worldPoint.x, z: worldPoint.z };
      mapProtractorCenterWorld = null;
      mapProtractorRotationRad = 0;
      mapProtractorMoveActive = false;
      mapProtractorSavedCenterWorld = null;
      mapProtractorSavedPlotTimerEndMs = null;
      mapProtractorSavedRotationRad = 0;
      mapProtractorHoverClient = { clientX: event.clientX, clientY: event.clientY };
      mapPlotTimerStartMs = performance.now();
      mapPlotTimerEndMs = null;
    } else {
      mapProtractorCenterWorld = { x: worldPoint.x, z: worldPoint.z };
      mapProtractorMoveActive = false;
      mapProtractorSavedCenterWorld = null;
      mapProtractorSavedPlotTimerEndMs = null;
      mapProtractorSavedRotationRad = 0;
      mapProtractorHoverClient = { clientX: event.clientX, clientY: event.clientY };
      if (mapPlotTimerStartMs != null && mapPlotTimerEndMs == null) {
        mapPlotTimerEndMs = performance.now();
      }
    }
    renderMap();
    updateStatus();
    return;
  }

  if (mapProtractorCenterWorld && !mapProtractorMoveActive) {
    renderMap();
    updateStatus();
    return;
  }

  if (!mapMeasureLineEnd) {
    mapMeasureLineEnd = { x: worldPoint.x, z: worldPoint.z };
    mapProtractorCenterWorld = null;
    mapProtractorMoveActive = false;
    mapProtractorRotationRad = 0;
    mapProtractorSavedCenterWorld = null;
    mapProtractorSavedPlotTimerEndMs = null;
    mapProtractorSavedRotationRad = 0;
    mapProtractorHoverClient = { clientX: event.clientX, clientY: event.clientY };
    mapPlotTimerStartMs = performance.now();
    mapPlotTimerEndMs = null;
    renderMap();
    updateStatus();
    return;
  }

  mapMeasureLineEnd = { x: worldPoint.x, z: worldPoint.z };
  mapProtractorCenterWorld = null;
  mapProtractorMoveActive = false;
  mapProtractorRotationRad = 0;
  mapProtractorSavedCenterWorld = null;
  mapProtractorSavedPlotTimerEndMs = null;
  mapProtractorSavedRotationRad = 0;
  mapProtractorHoverClient = { clientX: event.clientX, clientY: event.clientY };
  mapPlotTimerStartMs = performance.now();
  mapPlotTimerEndMs = null;
  renderMap();
  updateStatus();
}

function addCityBlocks() {
  const palette = [0x6b7280, 0x7d8795, 0x8d7766, 0x5e6b79, 0x7c6f62];

  for (let ix = -13; ix <= 13; ix += 1) {
    for (let iz = -13; iz <= 13; iz += 1) {
      const x = ix * 32;
      const z = iz * 32;

      const isAvenue = ix % 4 === 0 || iz % 4 === 0;
      const nearSpawnZone = Math.hypot(x - 4, z - 8) < 44;
      if (isAvenue || nearSpawnZone) {
        continue;
      }

      const width = 10 + (Math.abs(ix * 5 + iz * 3) % 4) * 3;
      const depth = 10 + (Math.abs(ix * 7 + iz * 2) % 4) * 3;
      const height = 14 + (Math.abs(ix * 11 + iz * 13) % 8) * 8;
      const color = palette[Math.abs(ix + iz) % palette.length];

      const building = new THREE.Mesh(
        new THREE.BoxGeometry(width, height, depth),
        new THREE.MeshStandardMaterial({
          color,
          roughness: 0.82,
          metalness: 0.08,
          emissive: new THREE.Color(color).multiplyScalar(0.03),
        }),
      );

      building.position.set(x + ((ix + iz) % 2) * 2, height / 2, z + ((ix - iz) % 2) * 2);
      building.castShadow = true;
      building.receiveShadow = true;
      scene.add(building);

      let roof = null;
      if ((ix + iz) % 3 === 0) {
        roof = new THREE.Mesh(
          new THREE.BoxGeometry(width * 0.42, 4 + (Math.abs(ix * iz) % 4) * 3, depth * 0.42),
          new THREE.MeshStandardMaterial({
            color: 0x525861,
            roughness: 0.76,
            metalness: 0.14,
          }),
        );
        roof.position.set(
          building.position.x,
          height + roof.geometry.parameters.height / 2,
          building.position.z,
        );
        roof.castShadow = true;
        roof.receiveShadow = true;
        scene.add(roof);
      }

      const structure = {
        building,
        roof,
        position: building.position.clone(),
        size: { width, height, depth },
        color,
        destroyed: false,
        isTower: height >= 42 && width <= 16 && depth <= 16,
        antenna: null,
      };
      destructibleStructures.push(structure);

      if (structure.isTower) {
        destructibleTowers.push(structure);
        const antenna = new THREE.Mesh(
          new THREE.CylinderGeometry(0.12, 0.12, 8 + (Math.abs(ix * iz) % 6), 8),
          new THREE.MeshStandardMaterial({
            color: 0x949ca8,
            roughness: 0.54,
            metalness: 0.48,
          }),
        );
        antenna.position.set(
          building.position.x,
          building.position.y + height / 2 + antenna.geometry.parameters.height / 2,
          building.position.z,
        );
        antenna.castShadow = true;
        scene.add(antenna);
        structure.antenna = antenna;
      }
    }
  }
}

function addTargetTowns() {
  for (const townSpec of TARGET_TOWN_SPECS) {
    const townCenter = new THREE.Vector3(
      MORTAR_POSITION.x + Math.cos(townSpec.angle) * townSpec.distance,
      0,
      MORTAR_POSITION.z + Math.sin(townSpec.angle) * townSpec.distance,
    );

    const sc = CITY_LAYOUT_SCALE;
    const town = {
      name: townSpec.name,
      center: townCenter,
      radius: 156 * sc,
      points: townSpec.points,
      destroyed: false,
      replayQueued: false,
      structures: [],
    };
    targetTowns.push(town);

    const villagePad = new THREE.Mesh(
      new THREE.CircleGeometry(148 * sc, 28),
      new THREE.MeshStandardMaterial({
        color: 0x8a7759,
        roughness: 1,
        metalness: 0,
      }),
    );
    villagePad.rotation.x = -Math.PI / 2;
    villagePad.position.copy(townCenter);
    villagePad.position.y = 0.012;
    villagePad.receiveShadow = true;
