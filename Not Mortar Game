/**
 * Half-width/height of the map in world feet (north-up, mortar-centered).
 * Uses at least MAP_WORLD_EXTENT so the view isn’t overly zoomed; wide panels approach 1000 ft per screen inch.
 */
function getMapHalfExtentFt() {
  const rect = mapCanvasElement.getBoundingClientRect();
  const css = Math.min(rect.width, rect.height);
  if (css < 8) {
    return MAP_WORLD_EXTENT;
  }
  const hIdeal = (MAP_RULER_FT_PER_CSS_INCH * css) / (2 * MAP_RULER_CSS_PX_PER_INCH);
  return Math.max(hIdeal, MAP_WORLD_EXTENT);
}

/** Ground feet represented by one screen inch on the map at current zoom (96 CSS px/in reference). */
function getMapFeetPerScreenInch() {
  const rect = mapCanvasElement.getBoundingClientRect();
  const css = Math.min(rect.width, rect.height);
  if (css < 8) {
    return MAP_RULER_FT_PER_CSS_INCH;
  }
  const H = getMapHalfExtentFt();
  return (2 * H * MAP_RULER_CSS_PX_PER_INCH) / css;
}

function getMapCenterXZ() {
  return { x: MORTAR_POSITION.x, z: MORTAR_POSITION.z };
}

/** North-up: +world Z maps toward the top of the map. Centered on mortar. */
function worldToMap(worldX, worldZ) {
  const canvasSize = mapCanvasElement.width;
  const H = getMapHalfExtentFt();
  const c = getMapCenterXZ();
  return {
    x: THREE.MathUtils.mapLinear(worldX, c.x - H, c.x + H, 0, canvasSize),
    y: THREE.MathUtils.mapLinear(worldZ, c.z - H, c.z + H, canvasSize, 0),
  };
}

function mapToWorld(pixelX, pixelY) {
  const rect = mapCanvasElement.getBoundingClientRect();
  if (rect.width < 1 || rect.height < 1) {
    return { x: 0, z: 0 };
  }
  const normalizedX = THREE.MathUtils.clamp((pixelX - rect.left) / rect.width, 0, 1);
  const normalizedY = THREE.MathUtils.clamp((pixelY - rect.top) / rect.height, 0, 1);
  const H = getMapHalfExtentFt();
  const c = getMapCenterXZ();
  return {
    x: THREE.MathUtils.mapLinear(normalizedX, 0, 1, c.x - H, c.x + H),
    z: THREE.MathUtils.mapLinear(normalizedY, 1, 0, c.z - H, c.z + H),
  };
}

function syncMapScaleKey() {
  if (!mapScaleKeyElement) {
    return;
  }
  const ftPerIn = Math.round(getMapFeetPerScreenInch());
  mapScaleKeyElement.innerHTML = `Map is <strong>north-up</strong> (top = +Z), centered on the <strong>mortar</strong>. Grid every <strong>${MAP_GRID_FT.toLocaleString()} ft</strong> — <em>no distance labels</em> on the grid. <strong>HE/HS plotting:</strong> (1) <strong>click</strong> aim, (2) <strong>Q</strong> — <strong>hollow half 45° set square</strong> follows the pointer (<strong>pivot</strong> = hypotenuse midpoint). <strong>Outer</strong> rulers on both short legs (large numbers) + matching <strong>inner</strong> scales on the frame; <strong>center line</strong> on the hypotenuse. After placing: <strong>left-drag on empty map</strong> (outside the triangle) <strong>left ↔ right</strong> to rotate the tool; <strong>left-drag on the tool</strong> to move it. While placed, <strong>plain clicks do not re-aim</strong> — <strong>Q</strong> unlocks, <strong>click</strong> sets new aim and <strong>removes</strong> the tool; <strong>Q</strong> again, then <strong>click</strong> to place. Second <strong>Q</strong> during follow cancels and restores prior tool. Legs <strong>${MAP_PROTRACTOR_LEG_INCHES}″</strong> @ <strong>${MAP_PROTRACTOR_FT_PER_TOOL_INCH.toLocaleString()} ft</strong>/in. ~<strong>${ftPerIn.toLocaleString()} ft</strong> per screen inch.`;
}

