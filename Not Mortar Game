    mapRings: 3,
    mapGap: 198,
    mapRgb: [255, 210, 160],
    wobbleMul: 0.42,
    opacityMul: 0.66,
    color: 0xffcc99,
  },
  carpetM0: { speedMul: 1, ringInner: 0.55, ringOuter: 1.35, seg: 22, mapRings: 2, mapGap: 160, mapRgb: [255, 198, 120], wobbleMul: 0.55, opacityMul: 0.5, color: 0xffc266 },
