function formatCarpetCooldownClock(totalSeconds) {
  const s = Math.max(0, Math.ceil(totalSeconds));
  const m = Math.floor(s / 60);
  const r = s % 60;
  return `${m}:${r.toString().padStart(2, "0")}`;
}

function getCarpetBombCooldownRemainingSec() {
  const now = performance.now();
  if (now >= carpetBombCooldownUntil) return 0;
  return (carpetBombCooldownUntil - now) / 1000;
}

function startCarpetBombRun(start, end) {
  if (activeCarpetBombRun?.plane) {
    disposeCarpetBombPlane(activeCarpetBombRun.plane);
    activeCarpetBombRun = null;
  }

  const dir = new THREE.Vector2(end.x - start.x, end.z - start.z);
  const length = dir.length();
  if (length < CARPET_BOMB_MIN_FT * 0.5) return;
  dir.normalize();

  const bombCount = CARPET_MICRO_BOMB_COUNT;
  const legDurationSec = Math.max(2.5, length / CARPET_PLANE_CRUISE_FT_PER_SEC);

  const plane = createCarpetBomberPlaneGroup();
  plane.position.set(start.x, 50, start.z);
  plane.rotation.y = Math.atan2(dir.x, dir.y);
  plane.rotation.x = -0.05;
  plane.rotation.z = 0.02;
  scene.add(plane);
  GameAudio.playJetDistant(plane.position);

  activeCarpetBombRun = {
    plane,
    start: { x: start.x, z: start.z },
    end: { x: end.x, z: end.z },
    dir: dir.clone(),
    progress: 0,
    bombCount,
    nextBombIndex: 0,
    cityBurstCooldown: 0,
    prevTownUnder: null,
    duration: legDurationSec,
    exiting: false,
    exitTime: 0,
    exitAltitude: 50,
  };

  carpetBombCooldownUntil = performance.now() + 120000;
}

function updateCarpetBombRun(delta) {
  if (!activeCarpetBombRun) return;
  const run = activeCarpetBombRun;

  if (run.exiting) {
    run.exitTime += delta;
    run.exitAltitude += delta * 42;
    const spd = 210;
    run.plane.position.x += run.dir.x * spd * delta;
    run.plane.position.z += run.dir.y * spd * delta;
    run.plane.position.y = run.exitAltitude;
    run.plane.rotation.x -= delta * 0.08;
    const propsExit = run.plane.userData.propMeshes;
    if (propsExit) {
      for (const pm of propsExit) {
        pm.rotation.x += delta * 18;
      }
    }

    const farFromOrigin = Math.hypot(run.plane.position.x, run.plane.position.z) > MAP_WORLD_EXTENT * 2.8;
    if (run.exitTime > 5.5 || farFromOrigin) {
      disposeCarpetBombPlane(run.plane);
      activeCarpetBombRun = null;
    }
    return;
  }

  const perpX = -run.dir.y;
  const perpZ = run.dir.x;
  const props = run.plane.userData.propMeshes;
  const legSubstepCap = 0.06;
  let legRemain = delta;
  while (legRemain > 1e-8) {
    const step = Math.min(legSubstepCap, legRemain);
    legRemain -= step;

    run.progress += step / run.duration;
    const t = THREE.MathUtils.clamp(run.progress, 0, 1);
    const x = run.start.x + (run.end.x - run.start.x) * t;
    const z = run.start.z + (run.end.z - run.start.z) * t;
    run.plane.position.set(x, 50, z);

    if (props) {
      for (const pm of props) {
        pm.rotation.x += step * 44;
      }
    }

    const townUnder = getTownUnderCarpetBomber(run.plane.position.x, run.plane.position.z);
    const crossedIntoTown = Boolean(townUnder && townUnder !== run.prevTownUnder);
    if (townUnder && run.nextBombIndex < run.bombCount) {
      run.cityBurstCooldown += step;
      if (crossedIntoTown || run.cityBurstCooldown >= CARPET_CITY_BURST_COOLDOWN_SEC) {
        run.cityBurstCooldown = 0;
        const hBurst = ((run.nextBombIndex * 2654435761) ^ (run.plane.position.x * 73856093)) >>> 0;
        const span = CARPET_CITY_BURST_MAX - CARPET_CITY_BURST_MIN + 1;
        let burst = CARPET_CITY_BURST_MIN + (hBurst % span);
        burst = Math.min(burst, run.bombCount - run.nextBombIndex);
        for (let b = 0; b < burst; b += 1) {
          const i = run.nextBombIndex;
          if (i >= run.bombCount) break;
          run.nextBombIndex += 1;
          const h1 = ((i * 2654435761) ^ (i * 2246822507)) >>> 0;
          const spread = (h1 / 4294967296 - 0.5) * 2;
          const lateral = spread * 9.5;
          const bx = run.plane.position.x + perpX * lateral;
          const bz = run.plane.position.z + perpZ * lateral;
          createCarpetMicroExplosion(new THREE.Vector3(bx, 0.1, bz), i);
        }
      }
    } else {
      run.cityBurstCooldown = 0;
    }
    run.prevTownUnder = townUnder ?? null;

    if (t >= 1) {
      run.exiting = true;
      run.exitTime = 0;
      run.exitAltitude = run.plane.position.y;
      run.plane.position.set(run.end.x, run.plane.position.y, run.end.z);
      break;
    }
  }
}

function updateCollapseChunks(delta) {
  for (let index = activeCollapseChunks.length - 1; index >= 0; index -= 1) {
    const chunk = activeCollapseChunks[index];
    chunk.velocity.y -= SHELL_GRAVITY * 1.08 * delta;
    chunk.mesh.position.addScaledVector(chunk.velocity, delta);
    chunk.mesh.rotation.x += chunk.spin.x * delta;
    chunk.mesh.rotation.y += chunk.spin.y * delta;
    chunk.mesh.rotation.z += chunk.spin.z * delta;

    if (chunk.mesh.position.y < 0.12) {
      chunk.mesh.position.y = 0.12;
      chunk.velocity.x *= 0.92;
      chunk.velocity.z *= 0.92;
      chunk.velocity.y *= -0.18;
      chunk.spin.multiplyScalar(0.94);
    }

    if (chunk.mesh.position.y <= 0.13 && chunk.velocity.lengthSq() < 0.45 && chunk.spin.lengthSq() < 0.3) {
      activeCollapseChunks.splice(index, 1);
    }
  }
}

function updateStructureBursts(delta) {
  for (let index = activeStructureBursts.length - 1; index >= 0; index -= 1) {
    const burst = activeStructureBursts[index];
    burst.age += delta;
    const progress = burst.age / burst.duration;
    const fade = Math.max(0, 1 - progress);

    burst.core.scale.setScalar(1 + progress * 9);
    burst.core.material.opacity = 0.95 * fade;
    burst.halo.scale.setScalar(1 + progress * 13);
    burst.halo.material.opacity = 0.62 * fade;
    burst.light.intensity = (24 + burst.sparks.length) * fade;

    for (const spark of burst.sparks) {
      spark.velocity.y -= SHELL_GRAVITY * 0.85 * delta;
      spark.mesh.position.addScaledVector(spark.velocity, delta);
      spark.mesh.material.opacity = fade;
      spark.mesh.scale.setScalar(1 + progress * 2.5);
    }

    if (progress >= 1) {
      scene.remove(burst.root);
      activeStructureBursts.splice(index, 1);
    }
  }
}

function updateFirePatches(delta) {
  for (let index = activeFirePatches.length - 1; index >= 0; index -= 1) {
    const patch = activeFirePatches[index];
    patch.age += delta;
    const progress = patch.age / patch.duration;
    const fade = Math.max(0.15, 1 - progress);
    patch.phase += delta * 6;
    const flicker = 0.8 + Math.sin(patch.phase) * 0.2 + Math.random() * 0.08;

    patch.flameCore.scale.set(1, 1.3 + flicker * 0.7, 1);
    patch.flameOuter.scale.set(1, 1.55 + flicker * 0.9, 1);
    patch.smoke.position.y += delta * 0.55;
    patch.smoke.scale.setScalar(1 + progress * 1.4);
    patch.smoke.material.opacity = 0.26 * fade;
    patch.flameCore.material.opacity = 0.88 * fade;
    patch.flameOuter.material.opacity = 0.62 * fade;
    patch.light.intensity = (8 + flicker * 8) * fade;

    if (progress >= 1) {
      scene.remove(patch.root);
      activeFirePatches.splice(index, 1);
    }
  }
}

function startGame() {
  gameStarted = true;
  startScreenElement.hidden = true;
  hudElement.classList.remove("hud--waiting");
  renderer.domElement.classList.add("pointer-active");
  void GameAudio.resume();
  updateStatus();
  renderer.domElement.requestPointerLock();
}

function updateStatus() {
  const viewLabel = currentView === "first" ? "First-person" : "Third-person";
  const pointerLabel = pointer.locked ? "mouse look active" : "click to look around";
  const startLabel = gameStarted ? pointerLabel : "press Start";
  const interactionLabel = getInteractionLabel();
  statusElement.textContent = `${viewLabel} camera | ${startLabel} | ${interactionLabel}`;
}

function getInteractionLabel() {
  if (!gameStarted) {
    return activeModelLabel;
  }

  if (mapOpen) {
    return carpetBombMode
      ? `carpet | pivot+aim+spin (Q/E wheel) | ≤${CARPET_BOMB_MAX_FT.toLocaleString()} ft | ${CARPET_MICRO_BOMB_COUNT} | C HUD compass ${compassMapOn ? "on" : "off"} | M/Esc`
      : `map | north rose + grid | HE: Q protractor | C = HUD compass ${compassMapOn ? "on" : "off"} (when map closed) | M/Esc${hasTrackingShellReady() ? " | click target" : ""}`;
  }

  if (binocularsActive) {
    return `binoculars ${BINOCULAR_MAGNIFICATIONS[binocularZoomIndex]}× | 1 / 2 / 3 = 10× · 50× · 100× | B stow`;
  }

  if (radioAwaitingGroundPickup) {
    return isNearRadioPickup()
      ? "COLLECT — press E to pick up radio (first pickup)"
      : "First-time radio — walk to gold COLLECT | 2 to cancel";
  }

  if (!hasBinoculars && isNearObject(binocularsCrateObject)) {
    return "press E to pick up binoculars (B = long-range view)";
  }

  if (heldRadio) {
    const cd = getCarpetBombCooldownRemainingSec();
    const cdNote =
      cd > 0 && hasRadio && !hasTrackingShellReady()
        ? ` | carpet cooling ${formatCarpetCooldownClock(cd)}`
        : "";
    if (hasTrackingShellReady()) {
      return `walkie-talkie | M opens mortar map (tracking shell) | 2 stow for carpet-only M${cdNote}`;
    }
    return `walkie-talkie | M for carpet bomb map | 2 to put away${cdNote}`;
  }
  if (!hasRadio && isNearObject(radioCrateObject)) {
    return radioIntroComplete
      ? "press E to take radio from crate"
      : "press E — radio rises in front (COLLECT) — E again to grab | 2 cancels";
  }

  const currentShellDefinition = getCurrentShellDefinition();
  const currentShellText = currentShellDefinition
    ? `${currentShellDefinition.name} - ${currentShellDefinition.description}`
    : activeModelLabel;

  if (trackedProjectile) {
    return "watching mortar shell — Z exit | map & move locked";
  }

  if (cinematicImpactTimer > 0) {
    return "impact view — Z exit | map & move locked";
  }

  if (activeTownReplay) {
    return `replay: ${activeTownReplay.name}`;
  }

  if (mortarRotateMode && isNearMortar()) {
    if (loadedShell) {
      return `${currentShellText} | rotate mode | A/D yaw | W/S pitch | E fire`;
    }
    if (heldShell) {
      return `${currentShellText} | rotate mode | A/D yaw | W/S pitch | E insert shell`;
    }
    return "rotate mode | A/D yaw | W/S pitch";
  }

  if (loadedShell) {
    if (currentShellDefinition?.requiresMapTarget && !trackingTarget) {
      return `${currentShellText} | press M to choose target`;
    }
    return isNearMortar() ? `${currentShellText} | press E to fire` : `${currentShellText} | loaded`;
  }

  if (heldShell) {
    if (currentShellDefinition?.requiresMapTarget && !trackingTarget) {
      return `${currentShellText} | press M to choose target`;
    }
    return isNearMortar() ? `${currentShellText} | press E to insert` : `${currentShellText} | holding`;
  }

  if (isNearShell()) {
    return `${currentShellText} | press E to pick up`;
  }

  if (isNearMortar()) {
    const b = hasBinoculars
      ? binocularsActive
        ? ` | binoculars ${BINOCULAR_MAGNIFICATIONS[binocularZoomIndex]}× (1/2/3) | B stow`
        : ` | B binoculars`
      : "";
    return `press R then A/D yaw, W/S pitch | C HUD compass${b}`;
  }

  return hasBinoculars
    ? binocularsActive
      ? `${activeModelLabel} | C HUD compass | binoculars ${BINOCULAR_MAGNIFICATIONS[binocularZoomIndex]}× (1/2/3) | B stow`
      : `${activeModelLabel} | C HUD compass | B binoculars`
    : `${activeModelLabel} | C toggles HUD compass`;
}

function update(delta) {
  if (!gameStarted) {
    return;
  }

  if (animationMixer) {
    animationMixer.update(delta);
  }

  updateTerrainShockwaves(delta);

  updateProjectiles(delta);
  updateExplosions(delta);
  updateLightExplosions(delta);
  updateCarpetBombRun(delta);
  updateCollapseChunks(delta);
  updateStructureBursts(delta);
  updateFirePatches(delta);
  if (radioDispatchTimer > 0) {
    radioDispatchTimer = Math.max(0, radioDispatchTimer - delta);
    updateRadioDisplay();
  }

  if (radioPickupGroup) {
    radioPickupGroup.rotation.y += delta * 2.4;
    const phase = (radioPickupGroup.userData.floatPhase += delta * 2.15);
    const ir = radioPickupGroup.userData.introRise;
    if (ir) {
      ir.t += delta;
      const k = THREE.MathUtils.clamp(ir.t / ir.dur, 0, 1);
      const ease = 1 - Math.pow(1 - k, 2.45);
      radioPickupGroup.position.y = THREE.MathUtils.lerp(ir.from, ir.to, ease);
      if (k >= 1) {
        delete radioPickupGroup.userData.introRise;
        radioPickupGroup.userData.baseY = ir.to;
      }
    } else {
      const baseY = radioPickupGroup.userData.baseY ?? radioPickupGroup.position.y;
      radioPickupGroup.position.y = baseY + Math.sin(phase) * 0.14;
    }
    const rv = radioPickupGroup.userData.radioVisual;
    if (rv) {
      const baseLy = radioPickupGroup.userData.radioBaseY ?? 0.2;
      rv.position.y = baseLy + Math.sin(phase * 1.85) * 0.07;
      rv.rotation.x = Math.sin(phase * 1.1) * 0.06;
      rv.rotation.z = Math.sin(phase * 0.95) * 0.07;
    }
    const r1 = radioPickupGroup.userData.goldRing;
    const r2 = radioPickupGroup.userData.goldRingOuter;
    if (r1) {
      r1.rotation.z += delta * 4.1;
      r1.position.y = 0.22 + Math.sin(phase * 1.6) * 0.04;
    }
    if (r2) {
      r2.rotation.z -= delta * 2.65;
      r2.position.y = 0.22 + Math.sin(phase * 1.6) * 0.04;
    }
  }
  if (cameraShakeTimer > 0) {
    cameraShakeTimer = Math.max(0, cameraShakeTimer - delta);
    cameraShakeAmount = Math.max(0, cameraShakeAmount - delta * 0.32);
  } else {
    cameraShakeAmount = Math.max(0, cameraShakeAmount - delta * 0.7);
  }

  if (
    !activeTownReplay &&
    pendingTownReplays.length > 0 &&
    pendingCameraShakes.length === 0 &&
    cameraShakeTimer <= 0 &&
    !trackedProjectile &&
    cinematicImpactTimer <= 0
  ) {
    startTownReplay();
  }

  player.rotation.y = pointer.yaw;
  cameraRig.rotation.x = pointer.pitch;

  const rotatingMortar = mortarRotateMode && isNearMortar() && !trackedProjectile && cinematicImpactTimer <= 0;
  if (rotatingMortar) {
    const yawInput = Number(keys.has("KeyD")) - Number(keys.has("KeyA"));
    const pitchInput = Number(keys.has("KeyW")) - Number(keys.has("KeyS"));

    if (yawInput !== 0) {
      mortarYaw -= yawInput * MORTAR_ROTATION_SPEED * delta;
      mortarRoot.rotation.y = mortarYaw;
    }

    if (pitchInput !== 0) {
      mortarPitch = THREE.MathUtils.clamp(
        mortarPitch - pitchInput * MORTAR_PITCH_SPEED * delta,
        MORTAR_MIN_PITCH,
        MORTAR_MAX_PITCH,
      );
      mortarTube.rotation.z = mortarPitch;
    }
  }

  const watchLocked = trackedProjectile || cinematicImpactTimer > 0;
  const moveX =
    rotatingMortar || watchLocked ? 0 : Number(keys.has("KeyD")) - Number(keys.has("KeyA"));
  const moveZ =
    rotatingMortar || watchLocked ? 0 : Number(keys.has("KeyW")) - Number(keys.has("KeyS"));

  if (!watchLocked && (moveX !== 0 || moveZ !== 0)) {
    const forward = new THREE.Vector3(0, 0, -1).applyAxisAngle(new THREE.Vector3(0, 1, 0), pointer.yaw);
    const right = new THREE.Vector3(1, 0, 0).applyAxisAngle(new THREE.Vector3(0, 1, 0), pointer.yaw);

    const moveDirection = new THREE.Vector3().addScaledVector(right, moveX).addScaledVector(forward, moveZ);

    if (moveDirection.lengthSq() > 0) {
      moveDirection.normalize();
      player.position.addScaledVector(moveDirection, MOVE_SPEED * delta);
      player.position.x = THREE.MathUtils.clamp(player.position.x, -MAP_LIMIT, MAP_LIMIT);
      player.position.z = THREE.MathUtils.clamp(player.position.z, -MAP_LIMIT, MAP_LIMIT);
    }
  }

  if (activeTownReplay) {
    updateTownReplay(delta);
  } else if (trackedProjectile || cinematicImpactTimer > 0) {
    updateProjectileTracking(delta);
  } else {
    if (birdsEyeView) {
      applyBirdsEyeCameraTransform(delta);
    } else {
      applyCameraTransform();
    }
  }
  updateTrajectoryPreview();
  syncCompassHud();
  if (mapOpen && !trackedProjectile) {
    renderMap();
  }
  updateStatus();
}

function render() {
  const delta = clock.getDelta();
  update(delta);
  renderer.render(scene, camera);
  requestAnimationFrame(render);
}

</script>
