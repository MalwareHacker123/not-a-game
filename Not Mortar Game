function loadPlayerModelWithProgress() {
  return new Promise((resolve, reject) => {
    const loader = new GLTFLoader();
    let currentUrlIndex = 0;

    function tryNext() {
      if (currentUrlIndex >= MODEL_URLS.length) {
        resolve();
        return;
      }
      const url = MODEL_URLS[currentUrlIndex];
      setLoadingProgress(
        15 + (currentUrlIndex / MODEL_URLS.length) * 55,
        `Loading model (${currentUrlIndex + 1}/${MODEL_URLS.length})...`,
      );
      loader.load(
        url,
        (gltf) => {
          const model = gltf.scene;
          const box = new THREE.Box3().setFromObject(model);
          const size = box.getSize(new THREE.Vector3());
          const targetHeight = 1.85;
          if (size.y > 0) model.scale.setScalar(targetHeight / size.y);
          model.rotation.y = MODEL_FORWARD_OFFSET;
          model.updateMatrixWorld(true);
          const scaledBox = new THREE.Box3().setFromObject(model);
          const center = scaledBox.getCenter(new THREE.Vector3());
          model.position.x -= center.x;
          model.position.z -= center.z;
          model.position.y -= scaledBox.min.y;
          model.traverse((c) => {
            if (c.isMesh) {
              c.castShadow = true;
              c.receiveShadow = true;
            }
          });
          avatarRoot.clear();
          avatarRoot.add(model);
          activeModelLabel = `player model (${url})`;
          if (gltf.animations.length > 0) {
            animationMixer = new THREE.AnimationMixer(model);
            animationMixer.clipAction(gltf.animations[0]).play();
          }
          updateCameraMode();
          resolve();
        },
        (xhr) => {
          const pct = xhr.lengthComputable ? (xhr.loaded / xhr.total) * 100 : 50;
          setLoadingProgress(
            15 + (currentUrlIndex / MODEL_URLS.length) * 55 + (pct / 100) * (55 / MODEL_URLS.length),
            `Loading model ${Math.round(pct)}%...`,
          );
        },
        () => {
          currentUrlIndex += 1;
          tryNext();
        },
      );
    }
    tryNext();
  });
}

function isClientInsideMapCanvas(clientX, clientY) {
  if (!mapCanvasElement) {
    return false;
  }
  const rect = mapCanvasElement.getBoundingClientRect();
  return (
    clientX >= rect.left &&
    clientX <= rect.right &&
    clientY >= rect.top &&
    clientY <= rect.bottom
  );
}

function applyMapProtractorDragFromPointerEvent(e) {
  if (!mapOpen || !mapProtractorDragging || !mapProtractorCenterWorld) {
    return;
  }
  if (mapProtractorDragPointerId != null && e.pointerId !== mapProtractorDragPointerId) {
    return;
  }
  if (mapProtractorDragMode === "scrubRotate") {
    let dx = e.movementX;
    if (!dx && mapProtractorDragLastClientX != null) {
      dx = e.clientX - mapProtractorDragLastClientX;
    }
    mapProtractorDragLastClientX = e.clientX;
    mapProtractorDragMovedPx += Math.abs(dx) + Math.abs(e.movementY);
    mapProtractorRotationRad += dx * MAP_PROTRACTOR_ROTATE_RAD_PER_CURSOR_PX;
    renderMap();
    return;
  }
  mapProtractorDragMovedPx += Math.abs(e.movementX) + Math.abs(e.movementY);
  const w = mapToWorld(e.clientX, e.clientY);
  const M = mapProtractorCenterWorld;
  if (mapProtractorDragMode !== "move") {
    mapProtractorDragMode = "move";
    mapProtractorDragGrabDx = M.x - w.x;
    mapProtractorDragGrabDz = M.z - w.z;
  }
  mapProtractorCenterWorld = {
    x: w.x + mapProtractorDragGrabDx,
    z: w.z + mapProtractorDragGrabDz,
  };
  renderMap();
}

function bindEvents() {
  let lastMapPickTime = 0;
  let lastMapPickX = 0;
  let lastMapPickY = 0;

  function pointInsideMapCanvas(clientX, clientY) {
    const rect = mapCanvasElement.getBoundingClientRect();
    return (
      clientX >= rect.left &&
      clientX <= rect.right &&
      clientY >= rect.top &&
      clientY <= rect.bottom
    );
  }

  function dispatchMapPick(clientX, clientY) {
    if (!mapOpen || mapOverlayElement.hidden) return;
    if (mapProtractorDragging) {
      return;
    }
    if (mapProtractorSuppressNextPick) {
      mapProtractorSuppressNextPick = false;
      return;
    }
    if (!pointInsideMapCanvas(clientX, clientY)) return;
    const now = performance.now();
    if (
      now - lastMapPickTime < 320 &&
      Math.hypot(clientX - lastMapPickX, clientY - lastMapPickY) < 14
    ) {
      return;
    }
    lastMapPickTime = now;
    lastMapPickX = clientX;
    lastMapPickY = clientY;
    handleMapClick({ clientX, clientY });
  }

  const onOverlayMapPointerUp = (event) => {
    if (event.isPrimary === false) return;
    if (event.pointerType === "mouse" && typeof event.button === "number" && event.button !== 0) {
      return;
    }
    if (mapProtractorDragging) {
      return;
    }
    const cx = event.clientX;
    const cy = event.clientY;
    queueMicrotask(() => dispatchMapPick(cx, cy));
  };

  mapOverlayElement.addEventListener("pointerup", onOverlayMapPointerUp, true);
  mapOverlayElement.addEventListener(
    "click",
    (event) => {
      if (typeof event.button === "number" && event.button !== 0) return;
      const cx = event.clientX;
      const cy = event.clientY;
      queueMicrotask(() => dispatchMapPick(cx, cy));
    },
    true,
  );
  mapOverlayElement.addEventListener(
    "touchend",
    (event) => {
      const touch = event.changedTouches[0];
      if (!touch) return;
      if (mapProtractorDragging) {
        return;
      }
      const cx = touch.clientX;
      const cy = touch.clientY;
      queueMicrotask(() => dispatchMapPick(cx, cy));
      event.preventDefault();
    },
    { capture: true, passive: false },
  );

  mapOverlayElement.addEventListener(
    "pointermove",
    (e) => {
      if (!mapOpen || carpetBombMode) {
        return;
      }
      mapOverlayLastPointerClient = { clientX: e.clientX, clientY: e.clientY };
      if (mapProtractorMoveActive) {
        mapProtractorHoverClient = { clientX: e.clientX, clientY: e.clientY };
        renderMap();
      }
    },
    true,
  );

  window.addEventListener("pointermove", applyMapProtractorDragFromPointerEvent, true);

  mapCanvasElement.addEventListener("pointermove", (e) => {
    if (mapOpen && carpetBombMode) {
      mapProtractorHoverClient = null;
      const rect = mapCanvasElement.getBoundingClientRect();
      carpetBombMousePos = { clientX: e.clientX, clientY: e.clientY, rect };
      renderMap();
    } else if (mapOpen) {
      carpetBombMousePos = null;
      if (!mapProtractorMoveActive) {
        if (isClientInsideMapCanvas(e.clientX, e.clientY)) {
          mapProtractorHoverClient = { clientX: e.clientX, clientY: e.clientY };
        } else {
          mapProtractorHoverClient = null;
        }
      }
    }
  });

  mapCanvasElement.addEventListener("pointerleave", () => {
    carpetBombMousePos = null;
    if (!mapProtractorMoveActive) {
      mapProtractorHoverClient = null;
    }
    if (mapOpen) {
      renderMap();
    }
  });

  mapCanvasElement.addEventListener("dblclick", (e) => {
    if (!mapOpen || carpetBombMode || hasTrackingShellReady() || trackedProjectile) {
      return;
    }
    if (!pointInsideMapCanvas(e.clientX, e.clientY)) {
      return;
    }
    e.preventDefault();
    mapMeasureLineEnd = null;
    mapProtractorCenterWorld = null;
    mapProtractorMoveActive = false;
    mapProtractorSavedCenterWorld = null;
    mapProtractorSavedPlotTimerEndMs = null;
    mapProtractorSavedRotationRad = 0;
    mapProtractorRotationRad = 0;
    mapProtractorDragging = false;
    mapProtractorDragPointerId = null;
    mapProtractorDragMode = null;
    mapProtractorDragLastClientX = null;
    mapProtractorSuppressNextPick = false;
    mapOverlayLastPointerClient = null;
    mapPlotTimerStartMs = null;
    mapPlotTimerEndMs = null;
    renderMap();
    updateStatus();
  });

  function endMapProtractorPointerDrag(event) {
    if (!mapProtractorDragging) {
      return;
    }
    if (mapProtractorDragPointerId != null && event.pointerId !== mapProtractorDragPointerId) {
      return;
    }
    mapProtractorDragging = false;
    mapProtractorDragPointerId = null;
    mapProtractorDragMode = null;
    mapProtractorDragLastClientX = null;
    mapProtractorSuppressNextPick = true;
    mapProtractorDragMovedPx = 0;
    try {
      mapCanvasElement.releasePointerCapture(event.pointerId);
    } catch (_) {
      /* ignore */
    }
    renderMap();
    updateStatus();
  }

  mapCanvasElement.addEventListener(
    "pointerdown",
    (e) => {
      if (
        !mapOpen ||
        carpetBombMode ||
        trackedProjectile ||
        cinematicImpactTimer > 0 ||
        hasTrackingShellReady() ||
        !mapMeasureLineEnd ||
        mapProtractorMoveActive ||
        !mapProtractorCenterWorld
      ) {
        return;
      }
      if (e.button !== 0) {
        return;
      }
      if (!pointInsideMapCanvas(e.clientX, e.clientY)) {
        return;
      }
      e.preventDefault();
      e.stopPropagation();
      mapProtractorDragging = true;
      mapProtractorDragPointerId = e.pointerId;
      mapProtractorDragMovedPx = 0;
      if (!mapProtractorScreenHit(e.clientX, e.clientY)) {
        mapProtractorDragMode = "scrubRotate";
        mapProtractorDragLastClientX = e.clientX;
        mapCanvasElement.setPointerCapture(e.pointerId);
        return;
      }
      const w = mapToWorld(e.clientX, e.clientY);
      const M = mapProtractorCenterWorld;
      mapProtractorDragMode = "move";
      mapProtractorDragGrabDx = M.x - w.x;
      mapProtractorDragGrabDz = M.z - w.z;
      mapProtractorDragLastClientX = null;
      mapCanvasElement.setPointerCapture(e.pointerId);
    },
    true,
  );

  window.addEventListener("pointerup", endMapProtractorPointerDrag);
  window.addEventListener("pointercancel", endMapProtractorPointerDrag);

  mapCanvasElement.tabIndex = 0;

  mapCanvasElement.addEventListener(
    "wheel",
    (e) => {
      if (!mapOpen) {
        return;
      }
      if (carpetBombMode && carpetBombLineStart) {
        e.preventDefault();
        carpetBombHeadingAdjust += Math.sign(e.deltaY) * CARPET_HEADING_STEP * 1.4;
        renderMap();
        return;
      }
    },
    { passive: false },
  );

  document.addEventListener(
    "keydown",
    (event) => {
      if (!gameStarted || !mapOpen || !carpetBombMode || !carpetBombLineStart) return;
      const rot = carpetBombRotationKeyDelta(event);
      if (rot === 0) return;
      event.preventDefault();
      event.stopPropagation();
      carpetBombHeadingAdjust += rot * CARPET_HEADING_STEP;
      renderMap();
      updateStatus();
    },
    true,
  );

  renderer.domElement.addEventListener("click", () => {
    if (!gameStarted || mapOpen) {
      return;
    }
    renderer.domElement.requestPointerLock();
  });

  document.addEventListener("pointerlockchange", () => {
    pointer.locked = document.pointerLockElement === renderer.domElement;
    updateStatus();
  });

  window.addEventListener("mousemove", (event) => {
    if (!gameStarted || !pointer.locked || mapOpen) {
      return;
    }

    pointer.yaw -= event.movementX * LOOK_SENSITIVITY;
    pointer.pitch -= event.movementY * LOOK_SENSITIVITY;
    pointer.pitch = THREE.MathUtils.clamp(pointer.pitch, -MAX_PITCH, MAX_PITCH);
  });

  window.addEventListener("keydown", (event) => {
    if (
      !gameStarted &&
      startScreenElement?.classList?.contains("ready") &&
      (event.code === "Enter" || event.code === "Space")
    ) {
      event.preventDefault();
      startGame();
      return;
    }
    if (
      [
        "KeyW",
        "KeyA",
        "KeyS",
        "KeyD",
        "KeyE",
        "KeyM",
        "KeyR",
        "KeyZ",
        "KeyV",
        "KeyB",
        "KeyC",
        "Digit1",
        "Digit2",
        "Digit3",
        "Space",
        "Escape",
      ].includes(event.code)
    ) {
      event.preventDefault();
    }

    if (!gameStarted) {
      return;
    }

    if (event.code === "Escape" && mapOpen) {
      closeMap();
      return;
    }

    if (event.code === "KeyC" && !event.repeat) {
      compassMapOn = !compassMapOn;
      event.preventDefault();
      if (mapOpen) {
        renderMap();
      }
      updateStatus();
      return;
    }

    if (event.code === "KeyQ" && !event.repeat) {
      const canUseProtractorQ =
        mapOpen &&
        !carpetBombMode &&
        !trackedProjectile &&
        cinematicImpactTimer <= 0 &&
        !hasTrackingShellReady() &&
        mapMeasureLineEnd;
      if (canUseProtractorQ) {
        event.preventDefault();
        if (mapProtractorMoveActive) {
          mapProtractorMoveActive = false;
          if (mapProtractorSavedCenterWorld) {
            mapProtractorCenterWorld = {
              x: mapProtractorSavedCenterWorld.x,
              z: mapProtractorSavedCenterWorld.z,
            };
            mapPlotTimerEndMs = mapProtractorSavedPlotTimerEndMs;
            mapProtractorRotationRad = mapProtractorSavedRotationRad;
            mapProtractorSavedCenterWorld = null;
            mapProtractorSavedPlotTimerEndMs = null;
            mapProtractorSavedRotationRad = 0;
          }
        } else {
          if (mapProtractorCenterWorld) {
            mapProtractorSavedCenterWorld = {
              x: mapProtractorCenterWorld.x,
              z: mapProtractorCenterWorld.z,
            };
            mapProtractorSavedPlotTimerEndMs = mapPlotTimerEndMs;
            mapProtractorSavedRotationRad = mapProtractorRotationRad;
          } else {
            mapProtractorSavedCenterWorld = null;
            mapProtractorSavedPlotTimerEndMs = null;
            mapProtractorSavedRotationRad = 0;
          }
          mapProtractorMoveActive = true;
          mapProtractorCenterWorld = null;
          mapPlotTimerEndMs = null;
          if (!mapProtractorHoverClient && mapOverlayLastPointerClient) {
            mapProtractorHoverClient = {
              clientX: mapOverlayLastPointerClient.clientX,
              clientY: mapOverlayLastPointerClient.clientY,
            };
          }
        }
        renderMap();
        updateStatus();
        return;
      }
    }

    if (event.code === "KeyB" && !event.repeat) {
      if (!gameStarted || mapOpen || !hasBinoculars || trackedProjectile || cinematicImpactTimer > 0) return;
      applyBinocularView(!binocularsActive);
      GameAudio.playShellClack(binocularsActive ? 0.14 : 0.2);
      updateStatus();
      return;
    }

    if (binocularsActive && (event.code === "Digit1" || event.code === "Digit2" || event.code === "Digit3") && !event.repeat) {
      const zi = event.code === "Digit1" ? 0 : event.code === "Digit2" ? 1 : 2;
      applyBinocularMagnificationIndex(zi);
      GameAudio.playShellClack(0.11);
      updateStatus();
      return;
    }

    if (event.code === "KeyM" && !event.repeat) {
      if (trackedProjectile || cinematicImpactTimer > 0) {
        if (mapOpen) closeMap();
        return;
      }
      if (heldRadio && hasRadio && !hasTrackingShellReady()) {
        toggleCarpetBombMap();
      } else {
        toggleTrackingMap();
      }
      return;
    }

    if (event.code === "Digit2" && !event.repeat) {
      if (!hasRadio && radioAwaitingGroundPickup) {
        despawnRadioPickup();
        radioAwaitingGroundPickup = false;
        GameAudio.playShellClack(0.12);
        updateStatus();
        return;
      }
      if (!hasRadio) {
        return;
      }
      if (heldRadio) {
        heldRadio = false;
        if (carpetBombMode) closeMap();
        refreshHeldRadio();
        updateRadioDisplay();
        refreshHeldShellAnchor();
        GameAudio.playShellClack(0.14);
        updateStatus();
        return;
      }
      heldRadio = true;
      if (heldShell) putBackShell();
      if (mapOpen && !carpetBombMode) closeMap();
      refreshHeldRadio();
      updateRadioDisplay();
      refreshHeldShellAnchor();
      GameAudio.playShellClack(0.2);
      updateStatus();
      return;
    }

    if (mapOpen) {
      return;
    }

    if (event.code === "KeyV" && !event.repeat) {
      if (activeTownReplay || trackedProjectile || cinematicImpactTimer > 0) return;
      if (binocularsActive) applyBinocularView(false);
      setBirdsEyeView(!birdsEyeView);
      updateStatus();
      return;
    }

    if (event.code === "KeyE" && !event.repeat) {
      handleInteraction();
    }

    if (
      event.code === "KeyR" &&
      !event.repeat &&
      !trackedProjectile &&
      cinematicImpactTimer <= 0 &&
      isNearMortar()
    ) {
      mortarRotateMode = !mortarRotateMode;
      GameAudio.playMortarRotateToggle();
      updateStatus();
    }

    keys.add(event.code);

    if (event.code === "KeyZ" && !event.repeat) {
      if (activeTownReplay) {
        return;
      }

      if (trackedProjectile || cinematicImpactTimer > 0) {
        endProjectileTracking();
        return;
      }

      currentView = currentView === "first" ? "third" : "first";
      updateCameraMode();
    }
  });

  window.addEventListener("keyup", (event) => {
    keys.delete(event.code);
  });

  window.addEventListener("resize", () => {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
  });
}

