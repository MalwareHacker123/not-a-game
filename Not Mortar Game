const GameAudio = (() => {
  let audioCtx = null;
  let masterGain = null;
  const tmpP = new THREE.Vector3();
  const tmpQ = new THREE.Vector3();

  function getCtx() {
    if (audioCtx) return audioCtx;
    const AC = window.AudioContext || window.webkitAudioContext;
    if (!AC) return null;
    audioCtx = new AC();
    masterGain = audioCtx.createGain();
    masterGain.gain.value = 0.88;
    masterGain.connect(audioCtx.destination);
    return audioCtx;
  }

  async function resume() {
    const c = getCtx();
    if (c?.state === "suspended") {
      await c.resume();
    }
  }

  function distanceToListener(worldPos) {
    player.getWorldPosition(tmpP);
    return tmpP.distanceTo(worldPos);
  }

  function spatialVolume(distanceFt, opts = {}) {
    const { power = 0.58, ref = 105, ceiling = 1.35, floor = 0.02 } = opts;
    const d = Math.max(10, distanceFt);
    const raw = ref / Math.pow(d, power);
    return THREE.MathUtils.clamp(raw, floor, ceiling);
  }

  /** Delayed blast wind: reference level at ≤3000 ft; each additional 1000 ft halves gain. */
  function windDistanceAttenuationFt(distanceFt) {
    const refFt = 3000;
    const stepFt = 1000;
    const extra = Math.max(0, distanceFt - refFt);
    return Math.pow(0.5, extra / stepFt);
  }

  /** Explosion sound arrival (same nominal speed as shock on ground). */
  const EXPLOSION_SOUND_SPEED = 1125;

  /** Carpet micro-bangs are throttled so 50 impacts do not stack hundreds of AudioNodes. */
  let carpetMicroBangAudioLastMs = 0;

  const SHELL_AUDIO_PROFILE = {
    highExplosive: { noiseMul: 1, rumbleMul: 1, fireMul: 1, hiPass: 1, peakMul: 1, noiseBright: 1 },
    highSpeed: { noiseMul: 0.68, rumbleMul: 0.52, fireMul: 0.42, hiPass: 1.22, peakMul: 1.08, noiseBright: 1.5 },
    tracking: { noiseMul: 0.45, rumbleMul: 0.35, fireMul: 0.2, hiPass: 1.42, peakMul: 1.12, noiseBright: 1.75 },
    light: { noiseMul: 0.4, rumbleMul: 0.28, fireMul: 0.14, hiPass: 1.32, peakMul: 0.95, noiseBright: 1.55 },
  };

  function shellFamilyForExplosionVariant(shellType) {
    if (shellType === "highSpeed") return "highSpeed";
    if (shellType === "tracking") return "tracking";
    return "highExplosive";
  }

  function rumbleVariantRow(shellType, variantIndex) {
    const fam = shellFamilyForExplosionVariant(shellType);
    const row = EXPLOSION_RUMBLE_VARIANTS[fam][THREE.MathUtils.euclideanModulo(variantIndex, 5)];
    return row;
  }

  function windVariantRow(shellType, variantIndex) {
    const fam = shellFamilyForExplosionVariant(shellType);
    return EXPLOSION_WIND_VARIANTS[fam][THREE.MathUtils.euclideanModulo(variantIndex, 5)];
  }

  function playExplosionAt(t0, worldPos, intensity = 1, shellType = "highExplosive", rumbleVariantIndex = 0) {
    const c = getCtx();
    if (!c) return;
    const t = Math.max(t0, c.currentTime + 0.004);
    const dist = distanceToListener(worldPos);
    const spatial = spatialVolume(dist, { ref: 210, power: 0.5, ceiling: 1.48, floor: 0.065 });
    const int = THREE.MathUtils.clamp(intensity, 0.15, 2.8);
    const far = THREE.MathUtils.clamp(dist / 14500, 0, 1);
    const distantAir = 0.68 + (1 - far) * 0.32;
    const prof = SHELL_AUDIO_PROFILE[shellType] ?? SHELL_AUDIO_PROFILE.highExplosive;
    let boom = spatial * (0.58 + int * 0.64) * distantAir * prof.peakMul;
    boom = Math.max(boom, 0.055 + int * 0.028);
    const punch = 1 + int * 0.12;
    const rumbleBoost = THREE.MathUtils.lerp(1.06, 1.74, far);
    const transientAtten = THREE.MathUtils.lerp(1, 0.22, far);
    const dimBright = THREE.MathUtils.lerp(1, 0.42, far);
    const boomRumble = boom * rumbleBoost;
    const rv = rumbleVariantRow(shellType, rumbleVariantIndex);

    const noiseDur = (0.68 + int * 0.86) * prof.noiseMul * rv.n;
    const nSamp = Math.max(256, Math.floor(c.sampleRate * noiseDur));
    const buf = c.createBuffer(1, nSamp, c.sampleRate);
    const ch = buf.getChannelData(0);
    let env = 1;
    for (let i = 0; i < nSamp; i++) {
      ch[i] = (Math.random() * 2 - 1) * env;
      env *= rv.env;
    }
    const noiseSrc = c.createBufferSource();
    noiseSrc.buffer = buf;
    const bp = c.createBiquadFilter();
    bp.type = "lowpass";
    bp.Q.value = 0.92;
    bp.frequency.setValueAtTime(4800 * prof.noiseBright * dimBright, t);
    bp.frequency.exponentialRampToValueAtTime(280 + 140 * (prof.noiseBright - 1), t + 0.11);
    bp.frequency.exponentialRampToValueAtTime(58 + 22 * (prof.noiseBright - 1), t + noiseDur * 0.94);
    const gN = c.createGain();
    gN.gain.setValueAtTime(0.0001, t);
    gN.gain.exponentialRampToValueAtTime(
      Math.min(1.38, boom * punch * 1.14 * transientAtten),
      t + 0.022,
    );
    gN.gain.exponentialRampToValueAtTime(0.0001, t + noiseDur + 0.04);
    const airLp = c.createBiquadFilter();
    airLp.type = "lowpass";
    const hiCut = THREE.MathUtils.lerp(9200, 520, far) / prof.hiPass;
    airLp.frequency.setValueAtTime(hiCut, t);
    airLp.Q.value = 0.72;
    airLp.connect(masterGain);
    noiseSrc.connect(bp);
    bp.connect(gN);
    gN.connect(airLp);
    noiseSrc.start(t);
    noiseSrc.stop(t + noiseDur + 0.1);

    const rumbleLen = (3.85 + int * 4.35) * prof.rumbleMul * rv.l;
    const rumbleGain = 0.56 * rv.rg;
    const sub = c.createOscillator();
    sub.type = "sine";
    sub.frequency.setValueAtTime((26 + Math.random() * 10) * rv.f, t);
    sub.frequency.exponentialRampToValueAtTime(6.2 * rv.f, t + rumbleLen * 0.74);
    const gSub = c.createGain();
    gSub.gain.setValueAtTime(0.0001, t);
    gSub.gain.exponentialRampToValueAtTime(boomRumble * punch * (0.62 + int * 0.32) * rumbleGain, t + 0.08);
    gSub.gain.exponentialRampToValueAtTime(boomRumble * punch * 0.3 * rumbleGain, t + rumbleLen * 0.32);
    gSub.gain.exponentialRampToValueAtTime(boomRumble * punch * 0.14 * rumbleGain, t + rumbleLen * 0.62);
    gSub.gain.exponentialRampToValueAtTime(boomRumble * punch * 0.05 * rumbleGain, t + rumbleLen * 0.88);
    gSub.gain.exponentialRampToValueAtTime(0.0001, t + rumbleLen + 0.85);
    sub.connect(gSub);
    gSub.connect(airLp);
    sub.start(t);
    sub.stop(t + rumbleLen + 0.95);

    const sub2 = c.createOscillator();
    sub2.type = "triangle";
    sub2.frequency.setValueAtTime((18 + Math.random() * 6) * rv.f, t);
    sub2.frequency.exponentialRampToValueAtTime(5.2 * rv.f, t + rumbleLen * 0.64);
    const g2 = c.createGain();
    g2.gain.setValueAtTime(0.0001, t);
    g2.gain.exponentialRampToValueAtTime(boomRumble * punch * (0.46 + int * 0.26) * rumbleGain, t + 0.1);
    g2.gain.exponentialRampToValueAtTime(boomRumble * punch * 0.19 * rumbleGain, t + rumbleLen * 0.4);
    g2.gain.exponentialRampToValueAtTime(boomRumble * punch * 0.07 * rumbleGain, t + rumbleLen * 0.78);
    g2.gain.exponentialRampToValueAtTime(0.0001, t + rumbleLen + 0.72);
    sub2.connect(g2);
    g2.connect(airLp);
    sub2.start(t);
    sub2.stop(t + rumbleLen + 0.88);

    const sub3 = c.createOscillator();
    sub3.type = "sine";
    sub3.frequency.setValueAtTime((13.5 + Math.random() * 4) * rv.f, t);
    sub3.frequency.exponentialRampToValueAtTime(4.2 * rv.f, t + rumbleLen * 0.8);
    const g3 = c.createGain();
    g3.gain.setValueAtTime(0.0001, t);
    g3.gain.exponentialRampToValueAtTime(boomRumble * punch * (0.34 + int * 0.16) * rumbleGain, t + 0.12);
    g3.gain.exponentialRampToValueAtTime(boomRumble * punch * 0.13 * rumbleGain, t + rumbleLen * 0.48);
    g3.gain.exponentialRampToValueAtTime(boomRumble * punch * 0.045 * rumbleGain, t + rumbleLen * 0.82);
    g3.gain.exponentialRampToValueAtTime(0.0001, t + rumbleLen + 0.68);
    sub3.connect(g3);
    g3.connect(airLp);
    sub3.start(t);
    sub3.stop(t + rumbleLen + 0.82);

    const beatF = (16 + Math.random() * 5) * rv.f;
    const beatOsc = c.createOscillator();
    beatOsc.type = "sine";
    beatOsc.frequency.setValueAtTime(beatF, t);
    beatOsc.frequency.exponentialRampToValueAtTime(5.5 * rv.f, t + rumbleLen * 0.7);
    const gBeat = c.createGain();
    const beatAmp = boomRumble * punch * (0.048 + far * 0.11) * rumbleGain * rv.ba;
    gBeat.gain.setValueAtTime(0.0001, t);
    gBeat.gain.exponentialRampToValueAtTime(beatAmp, t + 0.14);
    gBeat.gain.exponentialRampToValueAtTime(beatAmp * 0.35, t + rumbleLen * 0.55);
    gBeat.gain.exponentialRampToValueAtTime(0.0001, t + rumbleLen + 0.55);
    beatOsc.connect(gBeat);
    gBeat.connect(airLp);
    beatOsc.start(t);
    beatOsc.stop(t + rumbleLen + 0.65);

    const beatOsc2 = c.createOscillator();
    beatOsc2.type = "sine";
    beatOsc2.frequency.setValueAtTime(beatF * rv.bd, t);
    beatOsc2.frequency.exponentialRampToValueAtTime(5.8 * rv.f, t + rumbleLen * 0.7);
    const gBeat2 = c.createGain();
    gBeat2.gain.setValueAtTime(0.0001, t);
    gBeat2.gain.exponentialRampToValueAtTime(beatAmp * 0.92, t + 0.14);
    gBeat2.gain.exponentialRampToValueAtTime(beatAmp * 0.32, t + rumbleLen * 0.55);
    gBeat2.gain.exponentialRampToValueAtTime(0.0001, t + rumbleLen + 0.55);
    beatOsc2.connect(gBeat2);
    gBeat2.connect(airLp);
    beatOsc2.start(t);
    beatOsc2.stop(t + rumbleLen + 0.65);

    const padDur = THREE.MathUtils.clamp(
      (3.85 + int * 3.45) * (0.68 + far * 1.28) * prof.rumbleMul * rv.p,
      2.5,
      18,
    );
    const padN = Math.max(900, Math.floor(c.sampleRate * padDur));
    const pBuf = c.createBuffer(1, padN, c.sampleRate);
    const pCh = pBuf.getChannelData(0);
    let brown = 0;
    for (let i = 0; i < padN; i++) {
      brown += (Math.random() * 2 - 1) * 0.15;
      brown *= 0.991;
      const e = Math.pow(1 - i / padN, 0.2);
      pCh[i] = brown * e;
    }
    const padSrc = c.createBufferSource();
    padSrc.buffer = pBuf;
    const padLp = c.createBiquadFilter();
    padLp.type = "lowpass";
    padLp.frequency.setValueAtTime((125 + far * 95) * rv.pl, t);
    padLp.frequency.exponentialRampToValueAtTime((28 + far * 18) * rv.pl, t + padDur * 0.94);
    padLp.Q.value = 0.58;
    const gPad = c.createGain();
    const padAmp = boomRumble * punch * (0.11 + far * 0.58) * 0.62;
    gPad.gain.setValueAtTime(0.0001, t + 0.06);
    gPad.gain.exponentialRampToValueAtTime(Math.min(1.05, padAmp), t + 0.42 + far * 0.35);
    gPad.gain.exponentialRampToValueAtTime(Math.min(0.62, padAmp * 0.58), t + padDur * 0.48);
    gPad.gain.exponentialRampToValueAtTime(Math.min(0.22, padAmp * 0.22), t + padDur * 0.82);
    gPad.gain.exponentialRampToValueAtTime(0.0001, t + padDur + 0.35);
    padSrc.connect(padLp);
    padLp.connect(gPad);
    gPad.connect(airLp);
    padSrc.start(t + 0.03);
    padSrc.stop(t + padDur + 0.18);

    const fireDur =
      (0.82 + int * 1.52) * prof.fireMul * THREE.MathUtils.lerp(1, 0.62, far);
    const fireN = Math.max(200, Math.floor(c.sampleRate * fireDur));
    const fBuf = c.createBuffer(1, fireN, c.sampleRate);
    const fCh = fBuf.getChannelData(0);
    let crackle = 0;
    for (let i = 0; i < fireN; i++) {
      const p = i / fireN;
      const envelope = Math.pow(1 - p, 0.32) * (0.5 + 0.5 * Math.sin(p * Math.PI));
      crackle += (Math.random() - 0.5) * 4.2;
      crackle *= 0.87;
      fCh[i] = ((Math.random() * 2 - 1) * 0.7 + crackle * 0.24) * envelope;
    }
    const fireSrc = c.createBufferSource();
    fireSrc.buffer = fBuf;
    const fHp = c.createBiquadFilter();
    fHp.type = "highpass";
    fHp.frequency.value = 260;
    fHp.Q.value = 0.62;
    const fBp = c.createBiquadFilter();
    fBp.type = "bandpass";
    fBp.frequency.setValueAtTime(2400, t);
    fBp.frequency.exponentialRampToValueAtTime(380, t + fireDur * 0.9);
    fBp.Q.value = 0.58;
    const gFire = c.createGain();
    const fireMix = THREE.MathUtils.clamp((int - 0.12) / 2.5, 0, 1);
    let fireAmp =
      spatial * boom * (0.16 + int * 0.3) * (0.35 + fireMix * 0.65) * Math.sqrt(prof.fireMul) * distantAir;
    fireAmp *= transientAtten;
    gFire.gain.setValueAtTime(0.0001, t + 0.028);
    gFire.gain.exponentialRampToValueAtTime(Math.min(0.78, fireAmp * 1.05), t + 0.09);
    gFire.gain.exponentialRampToValueAtTime(Math.min(0.48, fireAmp * 0.55), t + fireDur * 0.48);
    gFire.gain.exponentialRampToValueAtTime(0.0001, t + fireDur + 0.08);
    fireSrc.connect(fHp);
    fHp.connect(fBp);
    fBp.connect(gFire);
    gFire.connect(airLp);
    fireSrc.start(t + 0.02);
    fireSrc.stop(t + fireDur + 0.08);
  }

  /** Blast wind / debris surge — arrives at 2× the sonic delay (slower than the initial shock rumble). */
  function playBlastWindAt(t0, worldPos, intensity = 1, shellType = "highExplosive", windVariantIndex = 0) {
    const c = getCtx();
    if (!c) return;
    const t = Math.max(t0, c.currentTime + 0.004);
    const dist = distanceToListener(worldPos);
    const spatial = spatialVolume(dist, { ref: 265, power: 0.48, ceiling: 1.62, floor: 0.09 });
    const int = THREE.MathUtils.clamp(intensity, 0.12, 2.8);
    const prof = SHELL_AUDIO_PROFILE[shellType] ?? SHELL_AUDIO_PROFILE.highExplosive;
    const far = THREE.MathUtils.clamp(dist / 14500, 0, 1);
    const windAir = 0.62 + (1 - far) * 0.38;
    const windBassBoost = THREE.MathUtils.lerp(1, 1.38, far);
    const wv = windVariantRow(shellType, windVariantIndex);
    const windDistAtten = windDistanceAttenuationFt(dist);
    const peak =
      spatial *
      (0.88 + int * 0.52) *
      windAir *
      prof.peakMul *
      windBassBoost *
      wv.pk *
      windDistAtten;

    const windDur = ((4.35 + int * 2.55) / Math.sqrt(0.55 + prof.rumbleMul)) * wv.d;
    const nSamp = Math.max(512, Math.floor(c.sampleRate * windDur));
    const buf = c.createBuffer(1, nSamp, c.sampleRate);
    const ch = buf.getChannelData(0);
    let brown = 0;
    for (let i = 0; i < nSamp; i++) {
      brown += (Math.random() * 2 - 1) * 0.16 * wv.br;
      brown *= 0.988;
      ch[i] = brown;
    }
    const src = c.createBufferSource();
    src.buffer = buf;
    const hp = c.createBiquadFilter();
    hp.type = "highpass";
    hp.frequency.value = THREE.MathUtils.lerp(72 * wv.hp, 108 * wv.hp, 1 - far);
    hp.Q.value = 0.52;
    const bp = c.createBiquadFilter();
    bp.type = "bandpass";
    bp.frequency.setValueAtTime((380 + far * 180) * wv.bpf, t);
    bp.frequency.exponentialRampToValueAtTime(2100 * wv.bpf, t + windDur * 0.32);
    bp.frequency.exponentialRampToValueAtTime((260 + far * 120) * wv.bpf, t + windDur * 0.9);
    bp.Q.value = THREE.MathUtils.clamp(0.4 + wv.bq, 0.28, 0.62);
    const gW = c.createGain();
    gW.gain.setValueAtTime(0.0001, t);
    gW.gain.exponentialRampToValueAtTime(Math.min(1.85, peak * 1.08), t + 0.22);
    gW.gain.exponentialRampToValueAtTime(Math.min(1.38, peak * 0.76), t + windDur * 0.52);
    gW.gain.exponentialRampToValueAtTime(0.0001, t + windDur + 0.28);
    const airLp = c.createBiquadFilter();
    airLp.type = "lowpass";
    airLp.frequency.setValueAtTime((5200 / prof.hiPass) * wv.lp, t);
    airLp.frequency.exponentialRampToValueAtTime((1450 / prof.hiPass) * wv.lp, t + windDur * 0.72);
    airLp.Q.value = 0.62;
    src.connect(hp);
    hp.connect(bp);
    bp.connect(gW);
    gW.connect(airLp);
    airLp.connect(masterGain);
    src.start(t);
    src.stop(t + windDur + 0.14);

    const gustDur = windDur * 0.92;
    const gN = Math.max(320, Math.floor(c.sampleRate * gustDur));
    const gBuf = c.createBuffer(1, gN, c.sampleRate);
    const gCh = gBuf.getChannelData(0);
    let env = 1;
    for (let i = 0; i < gN; i++) {
      gCh[i] = (Math.random() * 2 - 1) * env * 0.85 * Math.min(1.35, wv.br);
      env *= 0.9988;
    }
    const gSrc = c.createBufferSource();
    gSrc.buffer = gBuf;
    const gLp = c.createBiquadFilter();
    gLp.type = "lowpass";
    gLp.frequency.setValueAtTime((360 + far * 140) * wv.lp, t);
    gLp.frequency.exponentialRampToValueAtTime((62 + far * 38) * wv.lp, t + gustDur * 0.96);
    gLp.Q.value = 0.55;
    const gGust = c.createGain();
    const gustAmp = peak * (0.42 + far * 0.22) * (0.55 + int * 0.22) * wv.ga;
    gGust.gain.setValueAtTime(0.0001, t + 0.04);
    gGust.gain.exponentialRampToValueAtTime(gustAmp, t + 0.22);
    gGust.gain.exponentialRampToValueAtTime(gustAmp * 0.45, t + gustDur * 0.62);
    gGust.gain.exponentialRampToValueAtTime(0.0001, t + gustDur);
    gSrc.connect(gLp);
    gLp.connect(gGust);
    gGust.connect(airLp);
    gSrc.start(t + 0.02);
    gSrc.stop(t + gustDur + 0.08);
  }

  function scheduleExplosionSound(worldPos, intensity = 1, shellType = "highExplosive", opts = {}) {
    const c = getCtx();
    if (!c) return;
    void resume();
    const blast = worldPos.clone();
    const dist = distanceToListener(blast);
    const delayMs = THREE.MathUtils.clamp((dist / EXPLOSION_SOUND_SPEED) * 1000, 0, 60000);
    const windDelayMs = THREE.MathUtils.clamp(delayMs * 2 + 55, 0, 120000);
    const rumbleVariantPick = Math.floor(Math.random() * 5);
    const windVariantPick = Math.floor(Math.random() * 5);
    const skipWind = opts.skipWind === true;
    window.setTimeout(() => {
      void resume().then(() => {
        const c2 = getCtx();
        if (!c2) return;
        playExplosionAt(c2.currentTime + 0.02, blast, intensity, shellType, rumbleVariantPick);
      });
    }, delayMs);
    if (!skipWind) {
      window.setTimeout(() => {
        void resume().then(() => {
          const c2 = getCtx();
          if (!c2) return;
          playBlastWindAt(c2.currentTime + 0.02, blast, intensity, shellType, windVariantPick);
        });
      }, windDelayMs);
    }
  }

  function playExplosion(worldPos, intensity = 1, shellType = "highExplosive") {
    scheduleExplosionSound(worldPos, intensity, shellType);
  }

  function playLightExplosion(worldPos) {
    scheduleExplosionSound(worldPos, 0.28, "light", { skipWind: true });
  }

  function playCarpetMicroBang(worldPos, seed) {
    const nowMs = typeof performance !== "undefined" ? performance.now() : Date.now();
    if (nowMs - carpetMicroBangAudioLastMs < 88) {
      return;
    }
    carpetMicroBangAudioLastMs = nowMs;
    const c = getCtx();
    if (!c) return;
    void resume();
    const dist = distanceToListener(worldPos);
    const delayMs = THREE.MathUtils.clamp((dist / EXPLOSION_SOUND_SPEED) * 1000, 0, 55000);
    const mix = (a, b) => (((seed * 2654435761) ^ (a * 1597334677) ^ (b * 2246822507)) >>> 0) / 4294967296;
    window.setTimeout(() => {
      void resume().then(() => {
        const c2 = getCtx();
        if (!c2) return;
        const t = Math.max(c2.currentTime + 0.002, c2.currentTime);
        const spatial = spatialVolume(dist, { ref: 155, power: 0.53, ceiling: 0.36, floor: 0.007 });
        const f0 = 320 + mix(1, 2) * 3600;
        const f1 = 70 + mix(3, 4) * 480;
        const dur = 0.028 + mix(5, 6) * 0.062;
        const peak = spatial * (0.095 + mix(7, 8) * 0.16);
        const n = Math.max(100, Math.floor(c2.sampleRate * dur));
        const buf = c2.createBuffer(1, n, c2.sampleRate);
        const ch = buf.getChannelData(0);
        let rng = (seed * 1103515245 + 12345) >>> 0;
        const ph = mix(9, 10) * Math.PI * 2;
        for (let i = 0; i < n; i++) {
          rng = (rng * 1664525 + 1013904223) >>> 0;
          const r = rng / 4294967296;
          const u = i / n;
          const env = (1 - u) * (1 - u);
          ch[i] = (Math.sin(i * 0.17 + ph + seed * 0.01) * 0.26 + (r * 2 - 1) * 0.74) * env;
        }
        const src = c2.createBufferSource();
        src.buffer = buf;
        const bp = c2.createBiquadFilter();
        bp.type = "bandpass";
        bp.frequency.setValueAtTime(f0, t);
        bp.frequency.exponentialRampToValueAtTime(Math.max(45, f1), t + dur * 0.85);
        bp.Q.value = 0.55 + mix(11, 12) * 2.6;
        const g = c2.createGain();
        g.gain.setValueAtTime(0.0001, t);
        g.gain.exponentialRampToValueAtTime(peak, t + 0.0035 + mix(13, 14) * 0.014);
        g.gain.exponentialRampToValueAtTime(0.0001, t + dur + 0.018);
        src.connect(bp);
        bp.connect(g);
        g.connect(masterGain);
        src.start(t);
        src.stop(t + dur + 0.035);
        if (mix(15, 16) > 0.48) {
          const o = c2.createOscillator();
          o.type = mix(19, 20) > 0.5 ? "square" : "triangle";
          o.frequency.setValueAtTime(48 + mix(17, 18) * 160, t);
          o.frequency.exponentialRampToValueAtTime(22 + mix(21, 22) * 40, t + dur * 0.9);
          const g2 = c2.createGain();
          g2.gain.setValueAtTime(0.0001, t);
          g2.gain.exponentialRampToValueAtTime(peak * (0.22 + mix(23, 24) * 0.28), t + 0.006);
          g2.gain.exponentialRampToValueAtTime(0.0001, t + dur * 0.72);
          o.connect(g2);
          g2.connect(masterGain);
          o.start(t);
          o.stop(t + dur + 0.025);
        }
      });
    }, delayMs);
  }

  function playMortarLaunch(worldPos) {
