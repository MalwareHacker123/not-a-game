function horizontalDistanceXZ(a, b) {
  return Math.hypot(a.x - b.x, a.z - b.z);
}

function megacitySectionInBlastRange(epicenter, section, maxDist) {
  if (horizontalDistanceXZ(epicenter, section.center) <= maxDist) {
    return true;
  }
  for (let i = 0; i < section.structures.length; i += 1) {
    if (horizontalDistanceXZ(epicenter, section.structures[i].position) <= maxDist) {
      return true;
    }
  }
  return false;
}

function applyMegacityExplosionDamage(epicenter, shellDefinition, lightScale = 1) {
  for (const town of targetTowns) {
    if (!town.isMegacity || town.destroyed) continue;
    for (const section of town.sections) {
      if (section.destroyed) continue;
      if (!megacitySectionInBlastRange(epicenter, section, MEGA_SECTION_DAMAGE_RADIUS)) {
        continue;
      }
      const dist = horizontalDistanceXZ(epicenter, section.center);

      let dmg = 0;
      const id = shellDefinition.id;
      if (id === "tracking") dmg = 25;
      else if (id === "highSpeed") dmg = 28;
      else if (id === "highExplosive") {
        dmg = 50;
        if (dist < MEGA_HE_INSTA_KILL_RADIUS) dmg = 100;
      }

      dmg *= lightScale;
      const edge = THREE.MathUtils.clamp(1 - dist / MEGA_DAMAGE_FALLOFF_DENOM, 0.12, 1);
      dmg *= edge;

      section.hp -= dmg;
      if (section.hp <= 0) {
        destroyMegacitySection(town, section, epicenter);
      } else {
        updateMegacitySectionPad(section);
      }
    }
  }
}

function destroyMegacitySection(town, section, epicenter) {
  if (section.destroyed) return;
  section.hp = 0;
  section.destroyed = true;
  if (section.padMaterial) {
    section.padMaterial.color.setHex(0x4a4f55);
  }
  score += section.pointValue;
  updateScoreDisplay();

  const toShatter = [...section.structures];
  for (const st of toShatter) {
    if (!st.destroyed) {
      shatterStructure(st, epicenter, 0.95);
    }
  }

  if (town.sections.every((s) => s.destroyed)) {
    town.destroyed = true;
    updateScoreDisplay();
  }
}

