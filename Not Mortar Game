      scene.remove(exp.root);
      activeLightExplosions.splice(index, 1);
    }
  }
}

function disposeCarpetBombPlane(plane) {
  if (!plane) return;
  scene.remove(plane);
  plane.traverse((child) => {
    if (child.geometry) child.geometry.dispose();
    const mat = child.material;
    if (mat) {
      if (Array.isArray(mat)) mat.forEach((m) => m.dispose());
      else mat.dispose();
    }
  });
}

