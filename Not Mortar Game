async function loadPlayerModel() {
  const loader = new GLTFLoader();

  for (const modelUrl of MODEL_URLS) {
    try {
      const gltf = await loader.loadAsync(modelUrl);
      const model = gltf.scene;

      const box = new THREE.Box3().setFromObject(model);
      const size = box.getSize(new THREE.Vector3());
      const targetHeight = 1.85;

      if (size.y > 0) {
        const scale = targetHeight / size.y;
        model.scale.setScalar(scale);
      }

      model.rotation.y = MODEL_FORWARD_OFFSET;
      model.updateMatrixWorld(true);

      const scaledBox = new THREE.Box3().setFromObject(model);
      const center = scaledBox.getCenter(new THREE.Vector3());
      model.position.x -= center.x;
      model.position.z -= center.z;
      model.position.y -= scaledBox.min.y;

      model.traverse((child) => {
        if (child.isMesh) {
          child.castShadow = true;
          child.receiveShadow = true;
        }
      });

      avatarRoot.clear();
      avatarRoot.add(model);
      activeModelLabel = `player model (${modelUrl})`;

      if (gltf.animations.length > 0) {
        animationMixer = new THREE.AnimationMixer(model);
        animationMixer.clipAction(gltf.animations[0]).play();
      }

      updateCameraMode();
      return;
    } catch (error) {
      console.debug(`Model not found at ${modelUrl}`, error);
    }
  }

  activeModelLabel = "placeholder avatar";
  updateCameraMode();
}

