function startTownReplay() {
  if (pendingTownReplays.length === 0 || activeTownReplay) {
    return;
  }

  const replayData = pendingTownReplays.shift();
  const replayGroup = new THREE.Group();
  scene.add(replayGroup);

  for (const mesh of replayData.meshes) {
    replayGroup.add(mesh);
  }

  activeTownReplay = {
    name: replayData.name,
    center: replayData.center,
    impactPosition: replayData.impactPosition,
    incomingDirection: replayData.incomingDirection,
    group: replayGroup,
    staticMeshes: [...replayData.meshes],
    shell: createShell(replayData.shellType),
    shellStartPosition: replayData.impactPosition
      .clone()
      .sub(replayData.incomingDirection.clone().multiplyScalar(180))
      .setY(replayData.impactPosition.y + 80),
    shellDuration: 6,
    chunks: [],
    particles: [],
    smokePuffs: [],
    timer: 0,
    impactTriggered: false,
    duration: 12,
    orbitPhaseTime: 0,
    orbitAngle: 0,
  };

  activeTownReplay.shell.position.copy(activeTownReplay.shellStartPosition);
  activeTownReplay.group.add(activeTownReplay.shell);

  viewBeforeTownReplay = currentView;
  currentView = "third";
  mortarRotateMode = false;

  if (camera.parent !== scene) {
    scene.attach(camera);
  }
}

function triggerTownReplayImpact() {
  if (!activeTownReplay || activeTownReplay.impactTriggered) {
    return;
  }

  activeTownReplay.impactTriggered = true;
  const center = activeTownReplay.impactPosition;
  GameAudio.playExplosion(center, 0.62, "highExplosive");
  activeTownReplay.group.remove(activeTownReplay.shell);

  for (const mesh of activeTownReplay.staticMeshes) {
    const geometry = mesh.geometry.parameters ?? { width: 4, height: 4, depth: 4 };
    activeTownReplay.group.remove(mesh);

    const pieceCount = 3 + Math.floor(Math.random() * 3);
    for (let pieceIndex = 0; pieceIndex < pieceCount; pieceIndex += 1) {
      const chunk = new THREE.Mesh(
        new THREE.BoxGeometry(
          Math.max(0.35, (geometry.width ?? 4) * (0.28 + Math.random() * 0.26)),
          Math.max(0.35, (geometry.height ?? 4) * (0.24 + Math.random() * 0.22)),
          Math.max(0.35, (geometry.depth ?? 4) * (0.28 + Math.random() * 0.26)),
        ),
        mesh.material.clone(),
      );
      chunk.position.copy(mesh.position).add(
        new THREE.Vector3((Math.random() - 0.5) * 2.2, (Math.random() - 0.5) * 2.2, (Math.random() - 0.5) * 2.2),
      );
      chunk.castShadow = true;
      chunk.receiveShadow = true;
      activeTownReplay.group.add(chunk);

      const direction = chunk.position.clone().sub(center).setY(0);
      if (direction.lengthSq() === 0) {
        direction.set(Math.random() - 0.5, 0, Math.random() - 0.5);
      }
      direction.normalize();

      activeTownReplay.chunks.push({
        mesh: chunk,
        velocity: direction.multiplyScalar(14 + Math.random() * 18).setY(8 + Math.random() * 12),
        spin: new THREE.Vector3(2 + Math.random() * 5, 2 + Math.random() * 5, 2 + Math.random() * 5),
      });
    }
  }

  for (let index = 0; index < 18; index += 1) {
    const particle = new THREE.Mesh(
      new THREE.SphereGeometry(0.22, 8, 8),
      new THREE.MeshBasicMaterial({
        color: index % 2 === 0 ? 0xffc96e : 0xff6922,
        transparent: true,
        opacity: 1,
      }),
    );
    const angle = (Math.PI * 2 * index) / 18;
    const speed = 12 + Math.random() * 12;
    particle.position.copy(center).setY(5);
    activeTownReplay.group.add(particle);
    activeTownReplay.particles.push({
      mesh: particle,
      velocity: new THREE.Vector3(Math.cos(angle) * speed, 8 + Math.random() * 10, Math.sin(angle) * speed),
    });
  }

  for (let index = 0; index < 12; index += 1) {
    const puff = new THREE.Mesh(
      new THREE.SphereGeometry(2 + Math.random() * 1.8, 12, 12),
      new THREE.MeshBasicMaterial({
        color: index % 2 === 0 ? 0x564d49 : 0x36312f,
        transparent: true,
        opacity: 0.55,
      }),
    );
    puff.position.copy(center).add(
      new THREE.Vector3((Math.random() - 0.5) * 10, 4 + Math.random() * 8, (Math.random() - 0.5) * 10),
    );
    activeTownReplay.group.add(puff);
    activeTownReplay.smokePuffs.push({
      mesh: puff,
      velocity: new THREE.Vector3((Math.random() - 0.5) * 3, 4 + Math.random() * 5, (Math.random() - 0.5) * 3),
    });
  }
}

function updateTownReplay(delta) {
  if (!activeTownReplay) {
    return;
  }

  activeTownReplay.timer += delta;
  const center = activeTownReplay.impactPosition.clone();
  const lookTarget = center.clone().add(new THREE.Vector3(0, 8, 0));

  const shellProgress = THREE.MathUtils.clamp(activeTownReplay.timer / activeTownReplay.shellDuration, 0, 1);
  if (!activeTownReplay.impactTriggered) {
    const shellPosition = activeTownReplay.shellStartPosition.clone().lerp(activeTownReplay.impactPosition, shellProgress);
    shellPosition.y += Math.sin(shellProgress * Math.PI) * 40;
    activeTownReplay.shell.position.copy(shellPosition);
    activeTownReplay.shell.quaternion.copy(
      new THREE.Quaternion().setFromUnitVectors(new THREE.Vector3(0, 1, 0), activeTownReplay.incomingDirection),
    );

    const behindOffset = activeTownReplay.incomingDirection.clone().multiplyScalar(-42);
    behindOffset.y += 22;
    camera.position.copy(shellPosition).add(behindOffset);
    camera.lookAt(shellPosition);
  } else {
    activeTownReplay.orbitPhaseTime += delta;
    const transitionDuration = 2;
    const blend = THREE.MathUtils.smoothstep(
      THREE.MathUtils.clamp(activeTownReplay.orbitPhaseTime / transitionDuration, 0, 1),
      0,
      1,
    );

    activeTownReplay.orbitAngle += delta * 0.045;
    const orbit = activeTownReplay.orbitAngle;
    const radius = 70 + Math.sin(orbit * 0.6) * 25 + (1 - blend) * 40;
    const elevation = 0.35 + Math.sin(orbit * 0.4) * 0.2 + Math.sin(orbit * 1.2) * 0.08;
    const camX = center.x + Math.cos(orbit) * radius * Math.cos(elevation);
    const camY = center.y + radius * Math.sin(elevation) + 25;
    const camZ = center.z + Math.sin(orbit) * radius * Math.cos(elevation);

    if (blend < 1) {
      const behind = activeTownReplay.incomingDirection.clone().negate().multiplyScalar(38);
      behind.y = 28;
      const fromPos = center.clone().add(behind);
      camera.position.lerpVectors(fromPos, new THREE.Vector3(camX, camY, camZ), blend);
      camera.lookAt(lookTarget);
    } else {
      camera.position.set(camX, camY, camZ);
      camera.lookAt(lookTarget);
    }
  }

  if (!activeTownReplay.impactTriggered && shellProgress >= 1) {
    triggerTownReplayImpact();
  }

  const replayProgress = activeTownReplay.timer / activeTownReplay.duration;
  const replayFade = Math.max(0, 1 - replayProgress);

  for (const chunk of activeTownReplay.chunks) {
    chunk.velocity.y -= SHELL_GRAVITY * 0.95 * delta;
    chunk.mesh.position.addScaledVector(chunk.velocity, delta);
    chunk.mesh.rotation.x += chunk.spin.x * delta;
    chunk.mesh.rotation.y += chunk.spin.y * delta;
    chunk.mesh.rotation.z += chunk.spin.z * delta;
    if (chunk.mesh.position.y < 0.1) {
      chunk.mesh.position.y = 0.1;
      chunk.velocity.x *= 0.94;
      chunk.velocity.z *= 0.94;
      chunk.velocity.y *= -0.18;
      chunk.spin.multiplyScalar(0.94);
    }
  }

  for (const particle of activeTownReplay.particles) {
    particle.velocity.y -= SHELL_GRAVITY * 0.8 * delta;
    particle.mesh.position.addScaledVector(particle.velocity, delta);
    particle.mesh.material.opacity = 0.75 * replayFade;
  }

  for (const puff of activeTownReplay.smokePuffs) {
    puff.mesh.position.addScaledVector(puff.velocity, delta);
    puff.velocity.multiplyScalar(0.986);
    puff.mesh.scale.setScalar(1 + replayProgress * 3.4);
    puff.mesh.material.opacity = 0.42 * replayFade;
  }

  if (activeTownReplay.timer >= activeTownReplay.duration) {
    endTownReplay();
  }
}

function endTownReplay() {
  if (!activeTownReplay) {
    return;
  }

  scene.remove(activeTownReplay.group);
  activeTownReplay = null;
  currentView = viewBeforeTownReplay;

  if (camera.parent !== cameraRig) {
    cameraRig.attach(camera);
  }

  camera.rotation.set(0, 0, 0);
  updateCameraMode();
}

function getShellShockwaveVisual(shellId) {
  switch (shellId) {
    case "highSpeed":
      return { inner: 9.6, outer: 12.6, color: 0xa6f0ff, segments: 100, expandMul: 1.38 };
    case "tracking":
      return { inner: 5.1, outer: 8.6, color: 0x92ffc0, segments: 64, expandMul: 1.15 };
    default:
      return { inner: 8.5, outer: 13.2, color: 0xffdd88, segments: 88, expandMul: 1 };
  }
}

