/** Pivot at start: unit bearing = direction to mouse (XZ), spun by headingAdjust; run always uses full CARPET_BOMB_MAX_FT along that bearing (mouse only aims, not length). */
function carpetBombStrikeFromAim(startX, startZ, targetX, targetZ, headingAdjust = 0) {
  const dx = targetX - startX;
  const dz = targetZ - startZ;
  const rawChord = Math.hypot(dx, dz);
  let bx;
  let bz;
  if (rawChord < 8) {
    bx = Math.sin(pointer.yaw);
    bz = -Math.cos(pointer.yaw);
  } else {
    bx = dx / rawChord;
    bz = dz / rawChord;
  }
  const cosA = Math.cos(headingAdjust);
  const sinA = Math.sin(headingAdjust);
  const ux = bx * cosA - bz * sinA;
  const uz = bx * sinA + bz * cosA;
  const segmentLen = CARPET_BOMB_MAX_FT;
  return {
    start: { x: startX, z: startZ },
    end: { x: startX + ux * segmentLen, z: startZ + uz * segmentLen },
    segmentLen,
    ux,
    uz,
    aimChordLen: rawChord >= 8 ? rawChord : 0,
  };
}

function carpetBombRotationKeyDelta(event) {
  if (event.code === "Comma" || event.key === ",") return -1;
