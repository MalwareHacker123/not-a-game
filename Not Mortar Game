      transparent: true,
      opacity: 0.65,
    }),
  );
  burstRoot.add(halo);

  const light = new THREE.PointLight(0xffa347, 24 + blastStrength * 28, 58, 2);
  light.position.y = 2;
  burstRoot.add(light);

  const sparks = [];
