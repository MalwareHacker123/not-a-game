function updateProjectiles(delta) {
  for (let index = activeProjectiles.length - 1; index >= 0; index -= 1) {
    const projectile = activeProjectiles[index];
    let impactPosition = null;
    let impactDirection = null;

    if (projectile.type === "tracking") {
      projectile.progress += delta / projectile.duration;
      const progress = THREE.MathUtils.clamp(projectile.progress, 0, 1);
      const nextProgress = THREE.MathUtils.clamp(progress + 0.02, 0, 1);
      const currentPoint = projectile.start.clone().lerp(projectile.target, progress);
      const nextPoint = projectile.start.clone().lerp(projectile.target, nextProgress);
      currentPoint.y += Math.sin(progress * Math.PI) * 90;
      nextPoint.y += Math.sin(nextProgress * Math.PI) * 90;
      projectile.mesh.position.copy(currentPoint);

      const direction = nextPoint.clone().sub(currentPoint).normalize();
      if (direction.lengthSq() > 0) {
        projectile.mesh.quaternion.copy(new THREE.Quaternion().setFromUnitVectors(new THREE.Vector3(0, 1, 0), direction));
      }
      impactDirection = direction.clone();

      if (progress >= 1) {
        impactPosition = projectile.target.clone();
        impactPosition.y = 0.1;
      }
    } else {
      projectile.age += delta;
      projectile.velocity.y -= SHELL_GRAVITY * delta;
      projectile.mesh.position.addScaledVector(projectile.velocity, delta);

      const direction = projectile.velocity.clone().normalize();
      if (direction.lengthSq() > 0) {
        projectile.mesh.quaternion.copy(
          new THREE.Quaternion().setFromUnitVectors(new THREE.Vector3(0, 1, 0), direction),
        );
      }
      impactDirection = direction.clone();

      if (projectile.mesh.position.y <= 0.1 || projectile.age > 16) {
        impactPosition = projectile.mesh.position.clone();
        impactPosition.y = 0.1;
      }
    }

    if (impactPosition) {
      const impactedTown = getImpactedTown(impactPosition);
      scene.remove(projectile.mesh);
      activeProjectiles.splice(index, 1);
      if (trackedProjectile === projectile.mesh) {
        trackedProjectile = null;
        if (impactedTown) {
          endProjectileTracking();
        } else {
          cinematicImpactFocus = impactPosition.clone();
          cinematicImpactTimer = 2.05;
        }
      }
      createExplosion(impactPosition, projectile.shellDefinition);
    }
  }
}

function updateExplosions(delta) {
  for (let index = activeExplosions.length - 1; index >= 0; index -= 1) {
    const explosion = activeExplosions[index];
    explosion.age += delta;
    const progress = explosion.age / explosion.duration;
    const fade = Math.max(0, 1 - progress);
    const fireScale = explosion.blastProfile.fireScale;
    const cloudScale = explosion.blastProfile.cloudScale;

    const coreScale = fireScale * (1 + progress * 60);
    explosion.core.scale.setScalar(coreScale);
    explosion.core.material.opacity = 0.98 * fade;

    const outerScale = fireScale * (1 + progress * 74);
    explosion.outerFireball.scale.setScalar(outerScale);
    explosion.outerFireball.material.opacity = 0.94 * fade;

    const emberScale = fireScale * (1 + progress * 58);
    explosion.emberFireball.scale.setScalar(emberScale);
    explosion.emberFireball.material.opacity = 0.82 * fade;

    const haloScale = fireScale * (1 + progress * 90);
    explosion.blastHalo.scale.setScalar(haloScale);
    explosion.blastHalo.material.opacity = 0.38 * fade;

    const smokeScale = cloudScale * (1 + progress * 92);
    explosion.smokeCloud.scale.setScalar(smokeScale);
    explosion.smokeCloud.position.y = 1.8 + progress * 34;
    explosion.smokeCloud.material.opacity = 0.7 * fade;

    const stemScale = 1 + progress * 10;
    explosion.mushroomStem.scale.set(
      cloudScale * (1 + progress * 1.4),
      cloudScale * stemScale,
      cloudScale * (1 + progress * 1.4),
    );
    explosion.mushroomStem.position.y = 7 + progress * 40;
    explosion.mushroomStem.material.opacity = 0.56 * fade;

    const capScale = cloudScale * (1 + progress * 15);
    explosion.mushroomCap.scale.set(1.25 * capScale, cloudScale * (0.72 + progress * 2.4), 1.25 * capScale);
    explosion.mushroomCap.position.y = 15 + progress * 68;
    explosion.mushroomCap.material.opacity = 0.6 * fade;

    const shelfScale = cloudScale * (1 + progress * 12);
    explosion.mushroomShelf.scale.setScalar(shelfScale);
    explosion.mushroomShelf.position.y = 13.2 + progress * 54;
    explosion.mushroomShelf.material.opacity = 0.42 * fade;

    for (const puff of explosion.smokePuffs) {
      puff.mesh.position.addScaledVector(puff.velocity, delta);
      puff.velocity.multiplyScalar(0.985);
      puff.mesh.scale.setScalar(1 + progress * 8);
      puff.mesh.material.opacity = 0.45 * fade;
    }

    const shockMul = explosion.shockExpandMul ?? 1;
    const shockScale = 1 + progress * 120 * shockMul;
    explosion.shockwave.scale.setScalar(shockScale);
    explosion.shockwave.material.opacity = 0.92 * fade;

    explosion.scorch.scale.setScalar(1 + progress * 18);
    explosion.scorch.material.opacity = 0.78 * fade;

    explosion.flashLight.intensity = 220 * fade;

    for (const spark of explosion.sparks) {
      spark.velocity.y -= SHELL_GRAVITY * 0.7 * delta;
      spark.mesh.position.addScaledVector(spark.velocity, delta);
      spark.mesh.material.opacity = fade;
      spark.mesh.scale.setScalar(1 + progress * 10);
    }

    for (const chunk of explosion.debrisChunks) {
      chunk.velocity.y -= SHELL_GRAVITY * 1.25 * delta;
      chunk.mesh.position.addScaledVector(chunk.velocity, delta);
      chunk.mesh.rotation.x += chunk.spin.x * delta;
      chunk.mesh.rotation.y += chunk.spin.y * delta;
      chunk.mesh.rotation.z += chunk.spin.z * delta;

      if (chunk.mesh.position.y < 0.12) {
        chunk.mesh.position.y = 0.12;
        chunk.velocity.x *= 0.94;
        chunk.velocity.z *= 0.94;
        chunk.velocity.y *= -0.2;
        chunk.spin.multiplyScalar(0.96);
      }
    }

    for (const fragment of explosion.shrapnelPieces) {
      fragment.velocity.y -= SHELL_GRAVITY * 1.45 * delta;
      fragment.mesh.position.addScaledVector(fragment.velocity, delta);
      fragment.mesh.rotation.x += fragment.spin.x * delta;
      fragment.mesh.rotation.y += fragment.spin.y * delta;
      fragment.mesh.rotation.z += fragment.spin.z * delta;

      if (fragment.mesh.position.y < 0.08) {
        fragment.mesh.position.y = 0.08;
        fragment.velocity.x *= 0.98;
        fragment.velocity.z *= 0.98;
        fragment.velocity.y *= -0.08;
        fragment.spin.multiplyScalar(0.992);
      }
    }

    if (progress >= 1) {
      scene.remove(explosion.root);
      activeExplosions.splice(index, 1);
    }
  }
}

function updateLightExplosions(delta) {
  for (let index = activeLightExplosions.length - 1; index >= 0; index -= 1) {
